                                <tr>
                                    <th scope="row">術科場地地址2：<span class="text-primary"></span></th>
                                    <td>
                                        <span class="address3">@(strAddress32)</span>
                                        <span class="text-primary no-print"> <a target="_blank" href="@Html.Raw(s_href32)" rel="noreferrer noopener" title="開啟Google地圖查看術科場地位置(另開視窗)">開啟Google地圖(另開新視窗) <i class="fa fa-map-pin" aria-hidden="true"></i></a></span>
                                    </td>
                                </tr>
                            }

                            <tr>
                                <th>聯絡人：</th>
                                <td>@(string.IsNullOrEmpty(item.PCONTACTNAME) ? item.CONTACTNAME : item.PCONTACTNAME)</td>
                            </tr>
                            <tr>
                                <th>電話：</th>
