                                    }
                                    @*是否輔導學員參加政府機關辦理相關證照考試或技能檢定：<br><div class="radio"><label>
        @Html.RadioButtonFor(m => Model.Compare.Detail1[i].TGOVEXAM, "Y", new { @id = "Detail1[0]_TGOVEXAM_Y", @disabled = "disabled" })是，證照或檢定名稱
        @Html.TextBoxFor(m => Model.Compare.Detail1[i].TGOVEXAMNAME, new { @class = "form-normal" }, true)</label></div>
        <div class="radio"><label>@Html.RadioButtonFor(m => Model.Compare.Detail1[i].TGOVEXAM, "N", new { @id = "Detail1[1]_TGOVEXAM_N", @disabled = "disabled" })否</label></div>*@
                                </td>
