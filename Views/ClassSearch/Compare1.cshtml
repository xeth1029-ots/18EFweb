                                    {
                                        case 1:
                                            @:1.報名時應先繳全額訓練費用
                                            break;
                                        case 2:
                                            @:2.報名時應先繳50%訓練費用
                                            break;
                                        default:
                                            @:(請依規定繳費)
                                            break;
                                    }
                                </td>
                            </tr>
                            <tr>
                                <th>訓練費用：</th>
                                <td>
                                    <ul>
                                        <li>學員負擔：<span class="text-primary"><b>@(item.DEFSTDCOST == null ? "0" : string.Format("{0:N0}", item.DEFSTDCOST))</b></span></li>
                                        <li>政府負擔：<span class="text-primary"><b>@(item.DEFGOVCOST == null ? "0" : string.Format("{0:N0}", item.DEFGOVCOST))</b></span></li>
                                        <li>每班人數 ：<span class="text-primary"><b>@((item.TNUM == null ? "0" : item.TNUM.ToString()) + " 人")</b></span></li>
                                        <li>訓練時數 ： <span class="text-primary"><b>@((item.THOURS == null ? "0" : item.THOURS.ToString()) + " 小時")</b></span></li>
                                    </ul>
                                </td>
                            </tr>
                            <tr>
                                <th>訓練性質：</th>
                                <td>@(item.TPROPERTY)</td>
                            </tr>
                            <tr>
                                <th>報名日期 ：</th>
                                <td>
                                    @(item.SENTERDATE == null ? "" : (Convert.ToDateTime(item.SENTERDATE).Year - 1911).ToString() + Convert.ToDateTime(item.SENTERDATE).ToString("/MM/dd HH:mm"))  ~
                                    @(item.FENTERDATE == null ? "" : (Convert.ToDateTime(item.FENTERDATE).Year - 1911).ToString() + Convert.ToDateTime(item.FENTERDATE).ToString("/MM/dd HH:mm")) (若開放報名時間超過1個月以上，表示本班曾變更訓練期間)
                                </td>
