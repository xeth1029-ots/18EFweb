                                            @if (item2.STRAINDATE != null)
                                            {
                                                var tmpdt = Convert.ToDateTime(item2.STRAINDATE);
                                                string dayofweek = "";
                                                switch (Convert.ToString(tmpdt.DayOfWeek))
                                                {
                                                    case "Sunday": dayofweek = "星期日"; break;
                                                    case "Monday": dayofweek = "星期一"; break;
                                                    case "Tuesday": dayofweek = "星期二"; break;
                                                    case "Wednesday": dayofweek = "星期三"; break;
                                                    case "Thursday": dayofweek = "星期四"; break;
                                                    case "Friday": dayofweek = "星期五"; break;
                                                    case "Saturday": dayofweek = "星期六"; break;
                                                }
                                                @((tmpdt.Year - 1911).ToString() + tmpdt.ToString("/MM/dd") + "(" + dayofweek + ")")
                                            }
                                        </td>
                                        <td align="center">@(item2.PNAME)</td>
                                        <td align="center">@(item2.PHOUR)</td>
                                        <td>@item2.PCONT</td>
                                    </tr>
                                }
                            }
                        </table>
                        <div class="titlebar-note">本網頁課程資訊如與訓練單位公告事項不符時，仍以訓練單位公告資訊為準，恕不另行通知。</div>
                        <table width="100%" border="0" cellspacing="0" cellpadding="0" class="table-class">
                            <tr>
                                <th width="30%">訓練方式：</th>
                                <td width="70%">
                                    @(item.TRAINMODE)
                                </td>
                            </tr>
                            <tr><th>招訓方式：</th><td>@(item.RECRUIT)</td></tr>
                            <tr><th>遴選方式：</th><td>@(item.SELMETHOD)</td></tr>
                            <tr>
                                <th>是否為iCAP課程：</th>
