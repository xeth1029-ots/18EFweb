@using WDAIIP.WEB.Models
@using WDAIIP.WEB.DataLayers
@model ClassSearchViewModel
@{
    //for 產投
    ViewBag.Title = "課程查詢報名--課程比一比";
    Layout = "~/Views/Shared/_MainLayout_NoClassSearch.cshtml";
    SessionModel sess = SessionModel.Get();

}


@functions{
    /// <summary>取得該課程狀態</summary>
    /// <returns></returns>
    private string Get_ClassMsg(ClassSearchDetail1Model detail)
    {
        string result = "";
        //取得目前(DB)系統時間
        MyKeyMapDAO keyDao = new MyKeyMapDAO();
        DateTime nowTime = keyDao.GetSysDateNow();

        if (detail.SENTERDATE != null)
        {
            if (DateTime.Compare(nowTime, Convert.ToDateTime(detail.SENTERDATE)) < 0)
            {
                result = "目前尚未開始報名";
            }
            else
            {
                if (detail.FENTERDATE != null)
                {
                    result = (DateTime.Compare(nowTime, Convert.ToDateTime(detail.FENTERDATE)) > 0) ? "報名時間已結束" : ((detail.ISCLOSED == "Y") ? "此班已結訓" : "招生中");
                }
                else
                {
                    result = "報名結束時間尚未決定";
                }
            }
        }
        else
        {
            result = "報名時間尚未決定";
        }
        return result;
    }

    public string DistinctFormat(double? d)
    {
        return string.Format("{0: ###0.##}", d);
    }
}

<div class="col-sm-12">
