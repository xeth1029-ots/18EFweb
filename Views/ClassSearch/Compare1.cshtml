                                            @Html.RadioButtonFor(m => Model.Compare.Detail1[i].ISiCAPCOUR, "Y", new { @id = "Detail1_ISiCAPCOUR_Y", @disabled = "disabled" })是，課程相關說明
                                            @Html.TextBoxFor(m => Model.Compare.Detail1[i].iCAPCOURDESC, new { @class = "form-normal" }, true)
                                        </label>
                                    </div>
                                    <div class="radio"><label>@Html.RadioButtonFor(m => Model.Compare.Detail1[i].ISiCAPCOUR, "N", new { @id = "Detail1_ISiCAPCOUR_N", @disabled = "disabled" })否</label></div>
                                </td>
                            </tr>
                            <tr><th>iCAP標章證號：</th><td>@(item.iCAPNUM)</td></tr>
                            <tr><th>iCAP標章有效期：</th><td>@(s_icapdate)</td></tr>
                            <tr>
                                <th>其他：</th>
                                <td>
                                    @if (item.TGOVEXAM == "G")
                                    {
                                        <label>本課程結訓後須參加環境部辦理之淨零綠領人才培育課程測驗；測驗成績達及格，即可申請本方案補助。</label>
                                    }
                                    @if (item.TGOVEXAM == "Y" && string.IsNullOrEmpty(s_GOVAGENAME))
                                    {
