                                <td>@(item.STDATE == null ? "" : (Convert.ToDateTime(item.STDATE).Year - 1911).ToString() + Convert.ToDateTime(item.STDATE).ToString("/MM/dd"))  ~  @(item.FTDATE == null ? "" : (Convert.ToDateTime(item.FTDATE).Year - 1911).ToString() + Convert.ToDateTime(item.FTDATE).ToString("/MM/dd"))  </td>
                            </tr>
                            <tr>
                                <th>訓練期限 ：</th>
                                <td>@(item.TRAINEXPNAME)</td>
                            </tr>
                        </table>
                    </div>
                    <div class="table-responsive">
                        <table width="100%" border="0" cellspacing="0" cellpadding="0" class="table-class-blue">
