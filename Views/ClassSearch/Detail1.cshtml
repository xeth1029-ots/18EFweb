<script type="text/javascript">
    var serverdate = new Date();
    var senterdate = new Date();

    $(document).ready(function () {
        var btnstatus = '@Model.Detail.detail1.BtnStatus';
        var showmsg = '@Html.Raw(Model.Detail.detail1.ShowMsg)';
        var showEnter = '@(showEnter?"Y":"N")';

        $("a[data-role=EnterClass]").on("click", function () {
            doCheckData1X(btnstatus, showmsg);
        });

        $("button[data-role=EnterClass]").on("click", function () {
            doCheckData1X(btnstatus, showmsg);
        });

        //課程收藏 GoClassTrace
        $("a[data-role=GoClassTrace]").click(function () {
            var actionName = '@Url.Action("AddClassTrace","ClassSearch")';
            $("form#GoClassTraceForm").attr("action", actionName).submit();
        });

        //友善列印 GoPrint
        $("a[data-role=GoPrint]").click(doPrint);

        //招訓簡章下載,環境部淨零綠領人才培育課程班
        $("a[data-role=GoBroDownload]").click(doBroDownload);
        //招訓簡章下載
        $("a[data-role=GoPrintWGReport]").click(doPrintWGReport);

        //回上一頁 GoBack
        $("a[data-role=GoBack]").click(function () {
            $("form#GoBackForm").submit();
        });

        //server端時間
        var servertime = '@(strServerTime)';
        //報名起始時間
        var sentertime = '@(strSenterDate)';

        serverdate = moment(servertime, "YYYY/MM/DD HH:mm:ss.SSS");
        senterdate = moment(sentertime, "YYYY/MM/DD HH:mm:ss.SSS");

        //顯示系統時間
        if (btnstatus != "1" && btnstatus != "2") {
            showServerDate();
            setInterval(showServerDate, 1000);
        }
    });

    //--@*window.onfocus(function(){
