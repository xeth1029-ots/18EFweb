@using WDAIIP.WEB.Models
@using WDAIIP.WEB.Commons
@using WDAIIP.WEB.DataLayers
@using WDAIIP.WEB.Models.Entities
@model ClassSearchViewModel
@{
    //for 產投
    ViewBag.Title = "課程查詢報名--瀏覽課程明細";
    Layout = "~/Views/Shared/_MainLayout_NoClassSearchNoGTM.cshtml";

    //複製網址
    var cls_sch_url_1 = "https://ojt.wda.gov.tw/";
    var prompt_msg_1 = "（為加速報名作業，請事先登入會員，並確認會員資料無誤）";
    bool showEnter = false;

    //MyKeyMapDAO keyDao = new MyKeyMapDAO(); //取得目前(DB)系統時間
    DateTime nowTime = Model.GetSysDateNow();
    //「訓練班別」、「課程名稱」有期別則顯示期別
    var v_OJT22090201 = Model.GetSystemConfig("OJT22090201");
    bool flag_ShowClass2 = (!string.IsNullOrEmpty(v_OJT22090201) && v_OJT22090201 == "Y") ? true : false;
    string v_CLASSCNAME = flag_ShowClass2 ? Model.Detail.detail1.CLASSCNAME2 : Model.Detail.detail1.CLASSCNAME;

    SessionModel sess = SessionModel.Get();
    string strServerTime = nowTime.ToString("yyyy/MM/dd HH:mm:ss.fff"); //系統時間
    string s_ServerTime = nowTime.ToString("yyyyMMddHHmmssfff"); //系統時間2

    if (Model.Detail.detail1 == null) { return; }
    DateTime? senterdate = Model.Detail.detail1.SENTERDATE;
    DateTime? fenterdate = Model.Detail.detail1.FENTERDATE;
    DateTime? sdate = Model.Detail.detail1.STDATE;
    DateTime? fdate = Model.Detail.detail1.FTDATE;

    string strSenterDate = senterdate.HasValue ? senterdate.Value.ToString("yyyy/MM/dd HH:mm:ss.fff") : ""; //課程報名起日

    DateTime? icapdate = Model.Detail.detail1.iCAPMARKDATE;
    string s_icapdate = icapdate.HasValue ? icapdate.Value.ToString("yyyy/MM/dd") : ""; //iCAP標章有效期

    if ("1".Equals(Model.Detail.PlanType))
    {
        //複製網址
        cls_sch_url_1 = string.Format("https://ojt.wda.gov.tw/ClassSearch/Detail?OCID={0}&plantype={1}", Model.Detail.detail1.OCID.ToString(), Model.Detail.PlanType);
    }
    //如果不在報名期間不顯示報名鈕
    if ("1".Equals(Model.Detail.PlanType) && senterdate.HasValue && fenterdate.HasValue)
    {
        //if (DateTime.Compare(nowTime, Convert.ToDateTime(Model.Detail.detail1.SENTERDATE)) >= 0 && DateTime.Compare(nowTime, Convert.ToDateTime(Model.Detail.detail1.FENTERDATE)) <= 0)
        if (DateTime.Compare(nowTime, fenterdate.Value) <= 0) { showEnter = true; }
    }
    string classmsg = "報名時間尚未決定";
    if (senterdate.HasValue)
    {
        if (DateTime.Compare(nowTime, senterdate.Value) < 0)
        {
            classmsg = "目前尚未開始報名";
        }
        else
        {
            if (fenterdate.HasValue)
            {
                classmsg = (DateTime.Compare(nowTime, fenterdate.Value) > 0) ? "報名時間已結束" : ((Model.Detail.detail1.ISCLOSED == "Y") ? "此班已結訓" : "招生中");
            }
            else
            {
                classmsg = "報名結束時間尚未決定";
            }
        }
    }

    //遠距教學
    string s_DISTANCE_N = Model.GetDISTANCEN(Model.Detail.detail1.DISTANCE);
    string s_POINTYN = "非學分班";
    if (Model.Detail.detail1.POINTYN == "Y") { s_POINTYN = Convert.ToString(Model.Detail.detail1.CREDPOINT); }
    string s_CAPAGE1_N = "年滿15歲以上";
    if (Model.Detail.detail1.CAPAGE1.HasValue && Model.Detail.detail1.CAPAGE1 > 15)
    {
        s_CAPAGE1_N = string.Format("年滿應符合相關法規須年滿 {0} 以上歲以上", Model.Detail.detail1.CAPAGE1);
    }
    var strAddress21 = Model.Detail.detail1.ADDRESS21; //學科地址1
    var strAddress22 = Model.Detail.detail1.ADDRESS22; //學科地址2
    var strAddress31 = Model.Detail.detail1.ADDRESS31; //術科地址1
    var strAddress32 = Model.Detail.detail1.ADDRESS32; //術科地址2
    var strUrl21 = Model.Detail.detail1.HIDADDRESS21; //學科地址1(google)
    var strUrl22 = Model.Detail.detail1.HIDADDRESS22; //學科地址2(google)
    var strUrl31 = Model.Detail.detail1.HIDADDRESS31; //術科地址1(google)
    var strUrl32 = Model.Detail.detail1.HIDADDRESS32; //術科地址2(google)
    var s_GoogleMapUrl = "https://maps.google.com.tw/maps?hl=zh-TW&t=m&z=16&q={0}";
    var s_href21 = (!string.IsNullOrEmpty(strUrl21) && strUrl21.Length > 5) ? string.Format(s_GoogleMapUrl, HttpUtility.UrlEncode(strUrl21)) : null;
    var s_href22 = (!string.IsNullOrEmpty(strUrl22) && strUrl22.Length > 5) ? string.Format(s_GoogleMapUrl, HttpUtility.UrlEncode(strUrl22)) : null;
    var s_href31 = (!string.IsNullOrEmpty(strUrl31) && strUrl31.Length > 5) ? string.Format(s_GoogleMapUrl, HttpUtility.UrlEncode(strUrl31)) : null;
    var s_href32 = (!string.IsNullOrEmpty(strUrl32) && strUrl32.Length > 5) ? string.Format(s_GoogleMapUrl, HttpUtility.UrlEncode(strUrl32)) : null;
    var strAddressX = string.Empty;
    var strUrlX = string.Empty;
    var s_hrefX = string.Empty;
    if (string.IsNullOrEmpty(s_href21) && string.IsNullOrEmpty(s_href22) && string.IsNullOrEmpty(s_href31) && string.IsNullOrEmpty(s_href32))
    {
        strAddressX = string.Format("{0}{1}{2}{3}{4}", Model.Detail.detail1.ZIP1, Model.Detail.detail1.ZIP2, Model.Detail.detail1.CTNAME1, Model.Detail.detail1.ZIPNAME, Model.Detail.detail1.ADDRESS);
        strUrlX = string.Format("{0}{1}{2}{3}", Model.Detail.detail1.ZIP1, Model.Detail.detail1.CTNAME1, Model.Detail.detail1.ZIPNAME, Model.Detail.detail1.ADDRESS);
        s_hrefX = (!string.IsNullOrEmpty(strUrlX) && strUrlX.Length > 5) ? string.Format(s_GoogleMapUrl, HttpUtility.UrlEncode(strUrlX)) : null;
    }

    //string s_PHONE = string.IsNullOrEmpty(Model.Detail.detail1.CONTACTPHONE) ? Model.Detail.detail1.PHONE : Model.Detail.detail1.CONTACTPHONE;
    string s_PHONE = Model.Detail.detail1.CONTACTPHONE ?? "";
    string s_MOBILE = Model.Detail.detail1.CONTACTMOBILE ?? "";
    string s_CPHONEMOBILE = Model.GetCPHONEMOBILE(s_PHONE, s_MOBILE) ?? "";
    string s_ENVZEROTRAIN = Model.Detail.detail1.ENVZEROTRAIN ?? "";
    string s_GOVAGENAME = Model.Detail.detail1.GOVAGENAME ?? "";
    string s_TGOVEXAMNAME = Model.Detail.detail1.TGOVEXAMNAME ?? "";
    //招訓簡章
    string s_ENVGURL1 = "https://greencollar.moenv.gov.tw/MajorLeagueClass/Index";
    string s_GDR1 = s_ENVZEROTRAIN == "Y" ? "GoBroDownload" : "GoPrintWGReport";
    string s_GDR2 = s_ENVZEROTRAIN == "Y" ? "環境部淨零綠領人才培育課程班「另開新視窗」" : "下載pdf「另開新視窗」";
}


@functions {
    public string DistinctFormat(double? d)
    {
        if (!d.HasValue) return null;
        return string.Format("{0: ###0.##}", d);
    }
}

<div class="col-sm-12">
    <!-- bread start --->
    <div class="breadlink"><a title="中間主要功能選項區" accesskey="C" id="C" href="#C" style="text-decoration:none;">:::</a><i class="fa fa-home space-right" aria-hidden="true"></i>目前位置：<a href="@Url.Content("~/")" title="回首頁">首頁</a> / 課程查詢報名 / 課程查詢</div>
    <!-- bread end --->
    @using (Html.BeginForm("Print", "ClassSearch", FormMethod.Post, htmlAttributes: new { id = "main_form" }))
    {
        //報名鈕顯示隱藏控制判斷
        switch (Model.Detail.detail1.BtnStatus)
        {
            case "1": //反灰
            case "2": //隱藏 //不顯示倒數
                break;
            default:
                if ("1".Equals(Model.Detail.PlanType))
                {
                    <div class="titlebar-note text-center" id="time"></div>
                }
                break;
        }

        @*(Model.Detail.detail1.BtnStatus)*@
        @Html.HiddenFor(m => m.Detail.detail1.BtnStatus)
        <h3 class="main-title2 main-title-blue">
            <i class="fab fa-readme space-right"></i>瀏覽課程明細
            @if (showEnter)
            {
                <span class="text-yellow2">@(prompt_msg_1)</span>
            }
            <span class="no-print">
                @*報名鈕狀態(1:反灰、2:隱藏、3:系統提示訊息及HOME_NEWS3控制是否開放報名(反灰))*@
                @switch (Model.Detail.detail1.BtnStatus)
                {
                    case "2":
                        break;
                    default:
                        if (showEnter)
                        {
                            <a href="javascript:void(0);" title="我要報名" data-role="EnterClass" class="btn-titlebar bg-red">我要報名</a>
                        }
                        break;
                }
                @if ("1".Equals(Model.Detail.PlanType))
                {
                    <a href="javascript:void(0);" data-role="GoClassTrace" class="btn-titlebar bg-green" title="課程收藏">課程收藏</a>
                }
                <a href="javascript:void(0);" class="btn-titlebar bg-green copy_coupon" title="複製網址" id="BtnCopyUrl">複製網址</a>
                <a href="javascript:void(0);" data-role="GoPrint" class="btn-titlebar bg-green" title="列印">列印</a>
                @if ("1".Equals(Model.Detail.PlanType))
                {
                    <a href="javascript:void(0);" data-role="@(s_GDR1)" class="btn-titlebar bg-green" title="招訓簡章@(s_GDR2)"><span class="sr-only">@(s_GDR2)</span>招訓簡章下載</a>
                }
                @* 2018-07-11 暫時不放 //a href="javascript:void(0);" data-role="GoBack" class="btn-titlebar bg-green" title="回上一頁" 回上一頁a*@
            </span>
        </h3>

        <!-- class result start -->
        <h3 class="titlebar titlebarBg-green">訓練機構</h3>
        <div hidden>
            @Html.HiddenFor(m => m.Detail.OCID)
            @Html.HiddenFor(m => m.Detail.ProvideLocation)
            @Html.HiddenFor(m => m.Detail.PlanType)
        </div>

        <div class="table-responsive">
            <table width="100%" border="0" cellspacing="0" cellpadding="0" class="table-class">
                <tr>
                    <th width="15%" scope="row">訓練單位：</th>
                    <td width="35%">@(Model.Detail.detail1.ORGNAME)</td>
                    <th width="15%" scope="row">保險證號：<span class="text-primary"></span></th>
                    <td width="35%">@(Model.Detail.detail1.ACTNO)</td>
                </tr>
                <tr>
                    <th scope="row">學科場地地址：</th>
                    <td colspan="3">
                        @if (!string.IsNullOrEmpty(s_href21) && !string.IsNullOrEmpty(strAddress21))
                        {
                            <span class="address3">@(strAddress21)</span>
                            <span class="text-primary no-print"> <a target="_blank" href="@Html.Raw(s_href21)" rel="noreferrer noopener" title="開啟Google地圖查看學科場地位置(另開視窗)">開啟Google地圖(另開新視窗) <i class="fa fa-map-pin" aria-hidden="true"></i></a></span>
                            if (sess.IsLogin && Model.Detail.ProvideLocation == "Y" && Model.Detail.detail1.Distance1.HasValue)
                            {
                                @("，距離")<span class="text-success"> @(DistinctFormat(Model.Detail.detail1.Distance1)) </span>@("公里")
                            }
                        }
                        else if (!string.IsNullOrEmpty(s_hrefX) && !string.IsNullOrEmpty(strAddressX))
                        {
                            <span class="address3">@(strAddressX)</span>
                            <span class="text-primary no-print"> <a target="_blank" href="@Html.Raw(s_hrefX)" rel="noreferrer noopener" title="開啟Google地圖查看學科場地位置(另開視窗)">開啟Google地圖(另開新視窗) <i class="fa fa-map-pin" aria-hidden="true"></i></a></span>
                            if (sess.IsLogin && Model.Detail.ProvideLocation == "Y" && Model.Detail.detail1.Distance1.HasValue)
                            {
                                @("，距離")<span class="text-success"> @(DistinctFormat(Model.Detail.detail1.Distance1)) </span>@("公里")

                            }
                        }
                    </td>
                </tr>
                @if (!string.IsNullOrEmpty(s_href22))
                {
                    <tr>
                        <th scope="row">學科場地地址2：<span class="text-primary"></span></th>
                        <td colspan="3">
                            <span class="address3">@(strAddress22)</span>
                            <span class="text-primary no-print"> <a target="_blank" href="@Html.Raw(s_href22)" rel="noreferrer noopener" title="開啟Google地圖查看術科場地位置(另開視窗)">開啟Google地圖(另開新視窗) <i class="fa fa-map-pin" aria-hidden="true"></i></a></span>
                        </td>
                    </tr>
                }
                <tr>
                    <th scope="row">術科場地地址：<span class="text-primary"></span></th>
                    <td colspan="3">
                        @if (!string.IsNullOrEmpty(s_href31))
                        {
                            <span class="address3">@(strAddress31)</span>
                            <span class="text-primary no-print"> <a target="_blank" href="@Html.Raw(s_href31)" rel="noreferrer noopener" title="開啟Google地圖查看術科場地位置(另開視窗)">開啟Google地圖(另開新視窗) <i class="fa fa-map-pin" aria-hidden="true"></i></a></span>
                            if (sess.IsLogin && Model.Detail.ProvideLocation == "Y" && Model.Detail.detail1.Distance2.HasValue)
                            {
                                @("，距離")<span class="text-success"> @(DistinctFormat(Model.Detail.detail1.Distance2)) </span>@("公里")
                            }
                        }
                    </td>
                </tr>
                @if (!string.IsNullOrEmpty(s_href32))
                {
                    <tr>
                        <th scope="row">術科場地地址2：<span class="text-primary"></span></th>
                        <td colspan="3">
                            <span class="address3">@(strAddress32)</span>
                            <span class="text-primary no-print"> <a target="_blank" href="@Html.Raw(s_href32)" rel="noreferrer noopener" title="開啟Google地圖查看術科場地位置(另開視窗)">開啟Google地圖(另開新視窗) <i class="fa fa-map-pin" aria-hidden="true"></i></a></span>
                        </td>
                    </tr>
                }
                <tr>
                    <th scope="row">聯絡人：</th>
                    <td>@(string.IsNullOrEmpty(Model.Detail.detail1.PCONTACTNAME) ? Model.Detail.detail1.CONTACTNAME : Model.Detail.detail1.PCONTACTNAME)</td>
                    <th scope="row">電話：</th>
                    <td>@(s_CPHONEMOBILE)</td>
                </tr>
            </table>
        </div>

        <h3 class="titlebar titlebarBg-green">課程內容</h3>
        <div class="table-responsive">
            <table width="100%" border="0" cellspacing="0" cellpadding="0" class="table-class">
                <tr>
                    <th width="15%" scope="row">課程代碼：<br></th>
                    <td width="85%">@(Model.Detail.detail1.OCID)</td>
                </tr>
                <tr>
                    <th scope="row">瀏覽人次：<br></th>
                    <td>@(Model.Detail.detail1.BROWSECNT) 人</td>
                </tr>
                <tr>
                    <th scope="row">已報名人數：</th>
                    <td>@(Model.Detail.detail1.EnterCount + " 人") (已報名人數不等於錄訓人數，實際招生情形，請逕洽訓練單位)</td>
                </tr>
                <tr>
                    <th scope="row">課程名稱：</th>
                    <td><span class="text-classname">@(v_CLASSCNAME)</span><span class="text-DISTANCE">@Html.Raw(s_DISTANCE_N)</span></td>
                </tr>
                <tr>
                    <th scope="row">學分數：</th>
                    <td>@Html.Raw(s_POINTYN)</td>
                </tr>
                <tr>
                    <th>師資介紹：</th>
                    <td>
                        @if (Model.Detail.detail1.TeacherInfo != null)
                        {
                            for (int i = 0; i < Model.Detail.detail1.TeacherInfo.Count; i++)
                            {
                                TblTEACH_TEACHERINFO row = Model.Detail.detail1.TeacherInfo[i];
                                if (!string.IsNullOrEmpty(row.TEACHCNAME))
                                {
                                    <span class="text-primary">@(row.TEACHCNAME)&nbsp;老師</span>
                                }
                                if (!string.IsNullOrEmpty(row.SCHOOLNAME))
                                {
                                    @:<br />學歷：@(row.SCHOOLNAME)
                                }
                                if (!string.IsNullOrEmpty(row.DEPARTMENT))
                                {
                                    @:&nbsp;&nbsp;@(row.DEPARTMENT)
                                }

                                string strPro = "";
                                if (!string.IsNullOrEmpty(row.SPECIALTY1))
                                {
                                    strPro = row.SPECIALTY1;
                                }
                                if (!string.IsNullOrEmpty(row.SPECIALTY2))
                                {
                                    strPro += (strPro.Length > 0 ? "," : "");
                                    strPro += row.SPECIALTY2;
                                }
                                if (!string.IsNullOrEmpty(row.SPECIALTY3))
                                {
                                    strPro += (strPro.Length > 0 ? "," : "");
                                    strPro += row.SPECIALTY3;
                                }
                                if (!string.IsNullOrEmpty(row.SPECIALTY4))
                                {
                                    strPro += (strPro.Length > 0 ? "," : "");
                                    strPro += row.SPECIALTY4;
                                }
                                if (!string.IsNullOrEmpty(row.SPECIALTY5))
                                {
                                    strPro += (strPro.Length > 0 ? "," : "");
                                    strPro += row.SPECIALTY5;
                                }

                                if (strPro.Length > 0)
                                {
                                    @:<br />專長：@(strPro)
                                }
                                if (Model.Detail.detail1.TeacherInfo.Count != i + 1)
                                {
                                    <br /><br />
                                }
                            }
                        }
                    </td>
                </tr>
                <tr>
                    <th scope="row">縣 市 別：<br></th>
                    <td>
                        @if (!string.IsNullOrEmpty(Model.Detail.detail1.CTNAME1))
                        {
                            @(Model.Detail.detail1.CTNAME1)
                        }
                        else
                        {
                            if (Model.Detail.detail1.CTNAME2 != Model.Detail.detail1.CTNAME3)
                            {
                                if (!string.IsNullOrEmpty(Model.Detail.detail1.CTNAME2))
                                {
                                    @("(學科：" + Model.Detail.detail1.CTNAME2 + ")") //學科 縣市別
                                }
                                if (!string.IsNullOrEmpty(Model.Detail.detail1.CTNAME3))
                                {
                                    @("(術科：" + Model.Detail.detail1.CTNAME3 + ")") //術科 縣市別
                                }
                            }
                            else
                            {
                                if (!string.IsNullOrEmpty(Model.Detail.detail1.CTNAME2))
                                {
                                    @(Model.Detail.detail1.CTNAME2)
                                }
                            }
                        }
                    </td>
                </tr>
                <tr>
                    <th scope="row">訓練計畫：</th>
                    <td>@(Model.Detail.detail1.PLANNAME)</td>
                </tr>
                <tr>
                    <th scope="row">所屬計畫：</th>
                    <td>@(Model.Detail.detail1.ORGPLANNAME)</td>
                </tr>
                <tr>
                    <th scope="row">訓練班別：</th>
                    <td>@(v_CLASSCNAME + "(" + classmsg + ")")</td>
                </tr>
                <tr>
                    <th scope="row">報名繳費方式：</th>
                    <td>
                        @switch (Model.Detail.detail1.ENTERSUPPLYSTYLE)
                        {
                            case 1:
                                @:1.報名時應先繳全額訓練費用
                                break;
                            case 2:
                                @:2.報名時應先繳50%訓練費用
                                break;
                            default:
                                @:(請依規定繳費)
                                break;
                        }
                        &nbsp;&nbsp;<span color="red">@(Model.Detail.detail1.TOTALCOST_TEXT)</span>
                    </td>
                </tr>
                <tr>
                    <th scope="row">訓練費用：</th>
                    <td>
                        <ul>
                            <li>學員負擔：<span class="text-primary"><b>@(Model.Detail.detail1.DEFSTDCOST == null ? "0" : string.Format("{0:N0}", Model.Detail.detail1.DEFSTDCOST))</b></span></li>
                            <li>政府負擔：<span class="text-primary"><b>@(Model.Detail.detail1.DEFGOVCOST == null ? "0" : string.Format("{0:N0}", Model.Detail.detail1.DEFGOVCOST))</b></span></li>
                            <li>每班人數：<span class="text-primary"><b>@((Model.Detail.detail1.TNUM == null ? "0" : Model.Detail.detail1.TNUM.ToString()) + " 人")</b></span></li>
                            <li>訓練時數：<span class="text-primary"><b>@((Model.Detail.detail1.THOURS == null ? "0" : Model.Detail.detail1.THOURS.ToString()) + " 小時")</b></span></li>
                        </ul>
                    </td>
                </tr>
                <tr>
                    <th scope="row">訓練性質：</th>
                    <td>@(Model.Detail.detail1.TPROPERTY)</td>
                </tr>
                <tr>
                    <th scope="row">報名日期 ：</th>
                    <td>
                        @(Model.Detail.detail1.SENTERDATE == null ? "" : (Convert.ToDateTime(Model.Detail.detail1.SENTERDATE).Year - 1911).ToString() + Convert.ToDateTime(Model.Detail.detail1.SENTERDATE).ToString("/MM/dd HH:mm"))  ~
                        @(Model.Detail.detail1.FENTERDATE == null ? "" : (Convert.ToDateTime(Model.Detail.detail1.FENTERDATE).Year - 1911).ToString() + Convert.ToDateTime(Model.Detail.detail1.FENTERDATE).ToString("/MM/dd HH:mm")) (若開放報名時間超過1個月以上，表示本班曾變更訓練期間)
                    </td>
                </tr>
                <tr>
                    <th scope="row">預定訓練起訖日期：</th>
                    <td>@(Model.Detail.detail1.STDATE == null ? "" : (Convert.ToDateTime(Model.Detail.detail1.STDATE).Year - 1911).ToString() + Convert.ToDateTime(Model.Detail.detail1.STDATE).ToString("/MM/dd"))  ~  @(Model.Detail.detail1.FTDATE == null ? "" : (Convert.ToDateTime(Model.Detail.detail1.FTDATE).Year - 1911).ToString() + Convert.ToDateTime(Model.Detail.detail1.FTDATE).ToString("/MM/dd"))  </td>
                </tr>
                <tr>
                    <th scope="row">上課時間：</th>
                    <td>@(Model.Detail.detail1.WEEKSTIME) </td>
                </tr>
                <tr>
                    <th scope="row">訓練期限 ：</th>
                    <td>@(Model.Detail.detail1.TRAINEXPNAME)</td>
                </tr>
                <tr>
                    <th scope="row">專長能力：</th>@*專長能力標籤-PLAN_ABILITY*@
                    <td>
                        @foreach (var abilty in Model.Detail.detail1.AbilityGrid)
                        {
                            var s_a1 = abilty.ABILITY;
                            var s_a2 = abilty.ABILITY_DESC;
