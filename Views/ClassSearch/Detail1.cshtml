    //顯示系統時間（clock）
    function showServerDate() {
        var tmpDateTime = serverdate.add(1, "seconds");
        var yy = tmpDateTime.year() - 1911;
        var str = yy + tmpDateTime.format("/MM/DD HH:mm:ss");
        //$("div#time").html("現在時間為 " + str);
        countDownTime(tmpDateTime, senterdate);
    }

    //倒數計時（天時分秒）
    function countDownTime(serverTime, senterDate) {
        var diff = senterDate.diff(serverTime);
        var diffDuration = moment.duration(diff).add(1,"seconds");

        var yy = serverTime.year() - 1911;
        var str = yy + serverTime.format("/MM/DD HH:mm:ss");
        var datemsg = "現在時間為 " + str;
        var countmsg = "&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;距離開始報名時間剩餘 " + /*diffDuration.days()*/parseInt(diffDuration.asDays(),10) + " 天 " + diffDuration.hours() + " 時 " + diffDuration.minutes() + " 分 " + diffDuration.seconds() + " 秒";

        //未達報名起始時間時才顯示倒數計時
        $("div#time").html(datemsg + (diffDuration.asSeconds() >=0 ? countmsg : ""));
    }

    function timefunction() {
        serverdate.setSeconds(serverdate.getSeconds() + 1, 0);
        hourTemp = hour = serverdate.getHours();

        minuteTemp = minute = serverdate.getMinutes();
        if (minute.toString().length == 1)
            minuteTemp = "0" + minute.toString();

        secondTemp = second = serverdate.getSeconds();
        if (second.toString().length == 1)
            secondTemp = "0" + second.toString();

        monthnumberTemp = monthnumber = serverdate.getMonth();
        if ((monthnumber + 1).toString().length == 1)
            monthnumberTemp = "0" + (monthnumber + 1).toString();

        monthdayTemp = monthday = serverdate.getDate();
        if (monthday.toString().length == 1)
            monthdayTemp = "0" + monthday.toString();
        year = serverdate.getYear();
        ap = "上午";
        if (hour > 11) { ap = "下午"; }
        if (hour > 12) { hour = hour - 12; }
        if (hour == 0) { hour = 12; }
        if (hour.toString().length == 1)
            hourTemp = "0" + hour.toString();
        document.getElementById('time').innerHTML = "現在系統時間為 " + (year-1911) + "/" + monthnumberTemp + "/" + monthdayTemp + " " + ap + " " + hourTemp + ":" + minuteTemp + ":" + secondTemp;
    }

    //報名檢核
    function doCheckData1X(btnstatus, showmsg) {
        if (btnstatus == "1" || btnstatus == "3") {
            blockAlert(showmsg);
        }
        else {
            //檢查報名狀況
            var url = '@Url.Action("CheckData1X", "Ajax")';
            var data =
                {
                    ocid : '@Model.Detail.detail1.OCID'
                    ,plantype : '@Model.Detail.PlanType'
                };

            ajaxLoadMore(url, data, function (resp) {
                if (resp === undefined) {}
                else {
                    if (resp.data == null || resp.data == "") {
                        var actionName = '@Url.Action("Index","SignUp")';
                        $("form#GoClassTraceForm").attr("action", actionName).submit();
                    } else {
                        blockAlert(resp.data);
                        return false;
                    }
                }

            });
        }
    }

    //列印
    function doPrint() {
        var content = document.getElementById('main_form').innerHTML;
        var stime='@(s_ServerTime)';
        var sprint='Print'+stime;
        var mywindow = window.open('', sprint, '');

        var printstyle = '<style type="text/css">';
        printstyle += ' @@page{size: A4; margin: 35px;} ';
        printstyle += ' @@media print{ .no-print{display: none !important;}}';
        printstyle += '</style>';

        mywindow.document.write('<html><head><title></title>');
        mywindow.document.write('<link href="../css/base.css" rel="stylesheet" type="text/css">');
        mywindow.document.write(printstyle);
        mywindow.document.write('</head><body onload="window.print(); window.close();">');
        mywindow.document.write(content);
        mywindow.document.write('</body></html>');
        mywindow.document.close();
        mywindow.focus();
    }

    function doBroDownload() {
        var w2 = window.open('@(s_ENVGURL1)', 'dld2', 'toolbar=0,location=0,status=0,menubar=0,resizable=1');
        w2;
    }

    //招訓簡章下載
    function doPrintWGReport() {
        var url = "@Url.Action("GetWGReportMsg", "Ajax")";
        @if (Model.Detail.detail1.PLANID == null) {
            @:return;
                                                                                                                                                                                                                                                                                                                                                                                                                        }
        var data = { planid: @(Model.Detail.detail1.PLANID), ocid: @(Model.Detail.detail1.OCID), rid: '@(Model.Detail.detail1.RID)'};
        var rptUrl = "@ConfigModel.RptQuery_URL";
        var parms = "";

        var w = window.open('','print1','toolbar=0,location=0,status=0,menubar=0,resizable=1');
        ajaxLoadMore(url, data, function (resp) {
            //debugger;
            if (resp.data === undefined) {
                blockAlert("簡章下載失敗，請洽系統管理者!","",function(){});
            } else {
                console.log(resp.data);
                var item = resp.data;
                if (item != undefined)
                {
                    parms = "RptID=" + item.PRINTFILENAME;
                    parms += "&PMD=" + item.PMD;
                    parms += "&OCID=" + item.OCID;
                    parms += "&PCSV=" + item.PCSV;
                    parms += "&OKGW=" + item.ORGKINDGW;
                    //window.open(rptUrl + parms,"_blank");
                    w.location = rptUrl + parms;
                }
                else
                {
                    blockAlert("簡章下載失敗，請洽系統管理者!!","",function(){});
                }
            }
        });
    }

    // 檢視課程
    function showClassDetail(plantype, ocid) {
        var data = {
            "PlanType": plantype,
            "OCID": ocid,
            "ProvideLocation": "N"
        };
        var url = '@Url.Action("Detail", "ClassSearch")';
        goForwardPage(url, data, 2, "POST");
    }

    window.Clipboard = (function (window, document, navigator) {
        var textArea, copy;

        function isOS() {
            return navigator.userAgent.match(/ipad|iphone/i);
        }

        function createTextArea(text) {
            textArea = document.createElement('textArea');
            textArea.value = text;
            document.body.appendChild(textArea);
        }

        function selectText() {
            var range, selection;

            if (isOS()) {
                range = document.createRange();
                range.selectNodeContents(textArea);
                selection = window.getSelection();
                selection.removeAllRanges();
                selection.addRange(range);
                textArea.setSelectionRange(0, 999999);
            } else {
                textArea.select();
            }
        }

        function copyToClipboard() {
            document.execCommand("Copy");
            document.body.removeChild(textArea);
        }

        copy = function (text) {
            createTextArea(text);
            selectText();
            copyToClipboard();
        };

        return {
            copy: copy
        };
    })(window, document, navigator);

