}

@section scripts {
    @*enterTypeControllers.js*@
    @Scripts.Render("~/bundles/enterTypeD")
    <script>
        $(document).ready(function () {
            // 回個資確認頁 GoBack
            $("button[data-role=GoBack]").click(function () {
                var form = $("#GoBackForm");
                //var Epi=$('#Detail_epi').val(); var Epb=$('#Detail_epb').val(); var Ept=$('#Detail_ept').val();
                form.find("input[name='Epi']").val($('#Detail_epi').val());
                form.find("input[name='Epb']").val($('#Detail_epb').val());
                form.find("input[name='Ept']").val($('#Detail_ept').val());
                $("form#GoBackForm").submit();
            });
        });

        // 使用 replace 搭配正規表達式來尋找單一數字的月份和日期
        function formatMyDate(dateString) {
            // \b(\d{1})\b 匹配獨立的單一數字 (例如 8 或 9) // '0$1' 表示在匹配到的數字前加上 '0'
            return dateString.replace(/\b(\d{1})\b/g, '0$1');
        }

        // 報名資料維護 SaveData SaveUploadDBBC
        $("button[data-role=SaveData]").on("click", function () {
            //一律轉成：RocY/MM/dd;
            var TwBIRTH=formatMyDate($('#Detail_BIRTH_Y').val()+'/'+$('#Detail_BIRTH_M').val()+'/'+$('#Detail_BIRTH_D').val());
            var TwISSUEDATE=formatMyDate($('#Detail_ISSUE_Y').val()+'/'+$('#Detail_ISSUE_M').val()+'/'+$('#Detail_ISSUE_D').val());
            var form = $("#detail_form");
            TwBIRTH=$.trim(TwBIRTH);
            TwISSUEDATE=$.trim(TwISSUEDATE);
            var $DetailIDNO=$.trim($('#Detail_IDNO').val());
            var $DetailISSUINGPLACE=$.trim($('#Detail_ISSUINGPLACE').val());
            var Epi=$('#Detail_epi').val();
            var Epb=$('#Detail_epb').val();
            var Ept=$('#Detail_ept').val();
            form.find("input[name='Epi']").val($('#Detail_epi').val());
            form.find("input[name='Epb']").val($('#Detail_epb').val());
            form.find("input[name='Ept']").val($('#Detail_ept').val());
            form.find("input[name='ACID']").val($DetailIDNO);
            form.find("input[name='TwBIRTH']").val(TwBIRTH);
            form.find("input[name='TwISSUEDATE']").val(TwISSUEDATE);
            form.find("input[name='ISSUEPLACE']").val($DetailISSUINGPLACE);
            var url = "@Url.Action("GetSysDate2", "EnterType")";
            var data = { ACID:$DetailIDNO, TwBIRTH:TwBIRTH, TwISSUEDATE:TwISSUEDATE, ISSUEPLACE:$DetailISSUINGPLACE, Epi:Epi, Epb:Epb, Ept:Ept };
            ajaxLoadMore(url, data, function (resp) {
                var msg = (resp === undefined) ? "資料確認無誤，確定送出？": ("資料確認無誤，確定送出？<br>目前系統時間為(" + resp.data + ")");
                if(resp != undefined && !resp.status) {
                    var msg2=resp.data;
                    if(resp.data==undefined || resp.data==""){ msg2="(儲存上傳有誤,請重新操作)!"; }
                    blockAlert(msg2);
                    return;
                }
                else {
                    blockConfirm(msg, "提示訊息", function () {
                        form.submit();
                    });
                }
            });
        });

        $(function () {
            var enterTypeController = EnterTypeController(new Class);
            enterTypeController.fn.init({
                //共用元件
                commonController: CommonController(new Class),
                editData: @Html.Raw(Json.Encode(@ViewBag.EditData)),
            });
        });
    </script>
