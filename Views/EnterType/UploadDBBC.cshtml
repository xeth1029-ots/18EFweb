            fileNameSpan2.textContent = file2.name;
            canvasContainer2.style.display = "block";

            const reader2 = new FileReader(); //FileReader()javascript
            reader2.onload = function (e) {
                img2.onload = function () {
                    imgProps2.naturalWidth = img2.naturalWidth;
                    imgProps2.naturalHeight = img2.naturalHeight;
                    // 確保 drawImage 函數已定義
                    if (typeof drawImage2 === 'function') {
                        drawImage2();
                    }
                    else {
                        console.error("錯誤：drawImage() 函數未定義，無法繪製圖片。");
                    }
                };
                img2.src = e.target.result;
            };
            reader2.readAsDataURL(file2);
            fileNameSpan2.textContent = "請再按「上傳」,最後按「確定」";
            alert("請再按「上傳」,最後按「確定」");
        }

        // 繪製圖片
        function drawImage2() {
            // 確保圖片已經載入完成後再清除畫布
            img2.onload = function () {
                ctx2.clearRect(0, 0, canvas2.width, canvas2.height);  // 清除畫布
                // 計算圖片縮放比例
                imgProps2.scale = Math.min(canvas2.width / imgProps2.naturalWidth, canvas2.height / imgProps2.naturalHeight);
                const drawWidth2 = imgProps2.naturalWidth * imgProps2.scale;
                const drawHeight2 = imgProps2.naturalHeight * imgProps2.scale;
                // 繪製圖片到畫布
                ctx2.drawImage(img2, imgProps2.x, imgProps2.y, drawWidth2, drawHeight2);
                // 畫框
                //if (state.scanType === 'precise') {
                //    boxes.forEach(box => {
                //        ctx.strokeStyle = box.color;
                //        ctx.lineWidth = 2;
                //        ctx.strokeRect(box.x, box.y, box.width, box.height);
                //    });
                //}
            };
            img2.src = img2.src;
        }

        $(document).ready(function() {
            $('#openImageLink').on('click', function(event) {
                event.preventDefault(); // Prevent the default link behavior
                var imageUrl = $(this).attr('href'); // Get the href (image URL)
                window.open(imageUrl, '_blank'); // Open in a new tab/window
            });
        });

        $(document).ready(function () {
            setTimeout(() => {
                //document.querySelector('input[type="radio"][value="precise"]').checked = true;
                changeScanType("precise");
                let instructions = document.getElementById("instructions");
                let ocrTextResult = document.getElementById("ocrTextResult");
                instructions.style.display = "block";
                ocrTextResult.style.display = "none";
                if ($('input[type="radio"][value="precise"]').length > 0) { $('input[type="radio"][value="precise"]').prop('checked', true); }
                imgProps.isDragging = false;
                clearBoxesState(); //drawImage();
                //if ($('input[type="radio"][value="precise"]').length == 0){return;}
                if ($('input[type="radio"][value="full"]').length > 0) { $('input[type="radio"][value="full"]').parent('label').hide(); }
            }, 333); // 3000 milliseconds = 3 seconds
        });
    </script>
