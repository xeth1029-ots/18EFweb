        // 檔案選擇後觸發
        function fileChange(event) {
            const file = event.target.files[0];
            const fileNameSpan = document.getElementById("spanFileName");
            const canvasContainer = document.getElementById("canvasContainer");
            const instructions = document.getElementById("instructions");
            // 每次檔案選擇時，先重置顯示狀態，避免舊的狀態影響新的選擇
            fileNameSpan.textContent = "請選擇要上傳的檔案"; // 預設文字
            canvasContainer.style.display = "none"; // 預設隱藏
            $("#txtBackImgFromScan1").text('');

            // 如果沒有選擇檔案 (例如，使用者打開檔案選擇器後又取消)
            if (!file) { return; }

            if (!checkFile1(file)){return;}

            fileNameSpan.textContent = file.name;
            canvasContainer.style.display = "block";

            const reader = new FileReader(); //FileReader()javascript
            reader.onload = function (e) {
                img.onload = function () {
                    imgProps.naturalWidth = img.naturalWidth;
                    imgProps.naturalHeight = img.naturalHeight;
                    // 確保 drawImage 函數已定義
                    if (typeof drawImage === 'function') {
                        drawImage();
                    }
                    else {
                        console.error("錯誤：drawImage() 函數未定義，無法繪製圖片。");
                    }
                };
                img.src = e.target.result;
            };
            reader.readAsDataURL(file);
        }

        // 繪製圖片
        function drawImage() {
            // 確保圖片已經載入完成後再清除畫布
            img.onload = function () {
                ctx.clearRect(0, 0, canvas.width, canvas.height);  // 清除畫布
                // 計算圖片縮放比例
                imgProps.scale = Math.min(canvas.width / imgProps.naturalWidth, canvas.height / imgProps.naturalHeight);
                const drawWidth = imgProps.naturalWidth * imgProps.scale;
                const drawHeight = imgProps.naturalHeight * imgProps.scale;
                // 繪製圖片到畫布
                ctx.drawImage(img, imgProps.x, imgProps.y, drawWidth, drawHeight);
                // 畫框
                if (state.scanType === 'precise') {
                    boxes.forEach(box => {
                        ctx.strokeStyle = box.color;
                        ctx.lineWidth = 2;
                        ctx.strokeRect(box.x, box.y, box.width, box.height);
                    });
                }

            };
            img.src = img.src;
        }

        // 允許拖曳圖片
        function setBoxesState(isMouseDown, mouseX, mouseY) {
            let cursorStyle = "default"; // 預設樣式
            boxes.forEach(box => {
                const edgeBuffer = ctx.lineWidth / 2; // 根據 lineWidth 計算邊緣範圍
                // 檢查滑鼠是否在方框內部
                if (mouseX >= box.x - edgeBuffer && mouseX <= box.x + box.width + edgeBuffer && mouseY >= box.y - edgeBuffer && mouseY <= box.y + box.height + edgeBuffer) {
                    let isAtTopEdge = false;
                    let isAtBottomEdge = false;
                    let isAtLeftEdge = false;
                    let isAtRightEdge = false;
                    if (Math.abs(mouseY - box.y) <= edgeBuffer) {
                        isAtTopEdge = true;
                        if (isMouseDown) {
                            box.isResizingT = true;
                        }
                    }
                    if (Math.abs(mouseY - (box.y + box.height)) <= edgeBuffer) {
                        isAtBottomEdge = true;
                        if (isMouseDown) {
                            box.isResizingB = true;
                        }
                    }
                    if (Math.abs(mouseX - (box.x)) <= edgeBuffer) {
                        isAtLeftEdge = true;
                        if (isMouseDown) {
                            box.isResizingL = true;
                        }
                    }
                    if (Math.abs(mouseX - (box.x + box.width)) <= edgeBuffer) {
                        isAtRightEdge = true;
                        if (isMouseDown) {
                            box.isResizingR = true;
                        }
                    }
                    if ((isAtTopEdge && isAtLeftEdge) || (isAtBottomEdge && isAtRightEdge)) {
                        cursorStyle = "nwse-resize";
                    }
                    else if ((isAtTopEdge && isAtRightEdge) || (isAtBottomEdge && isAtLeftEdge)) {
                        cursorStyle = "nesw-resize";
                    }
                    else if (isAtTopEdge || isAtBottomEdge) {
                        cursorStyle = "ns-resize";
                    }
                    else if (isAtLeftEdge || isAtRightEdge) {
                        cursorStyle = "ew-resize";
                    }
                    else {
                        cursorStyle = "move";
                        if (isMouseDown) {
                            box.isDragging = true;
                        }
                    }
                }
            });

            // 更新游標樣式
            canvas.style.cursor = cursorStyle;
            return cursorStyle !== "default";
        }

        function setBoxesPositionAndSize(mouseX, mouseY) {
            boxes.forEach(box => {
                let dx = mouseX - mouseDownPosition.x;
                let dy = mouseY - mouseDownPosition.y;
                if (box.isDragging) {
                    box.x = dx + box.positionWhenMouseDown.x;
                    box.y = dy + box.positionWhenMouseDown.y;
                }
                else {
                    if (box.isResizingT) {
                        box.y = box.positionWhenMouseDown.y + dy;
                        box.height = box.sizeWhenMouseDown.height - dy;
                    }
                    if (box.isResizingB) {
                        box.height = box.sizeWhenMouseDown.height + dy;
                    }
                    if (box.isResizingL) {
                        box.x = box.positionWhenMouseDown.x + dx;
                        box.width = box.sizeWhenMouseDown.width - dx;
                    }
                    if (box.isResizingR) {
                        box.width = box.sizeWhenMouseDown.width + dx;
                    }
                }
            });
        }

        function clearBoxesState() {
            boxes.forEach((box) => {
                box.isDragging = false;
                box.isResizingT = false;
                box.isResizingB = false;
                box.isResizingL = false;
                box.isResizingR = false;
                box.positionWhenMouseDown.x = box.x;
                box.positionWhenMouseDown.y = box.y;
                box.sizeWhenMouseDown.width = box.width;
                box.sizeWhenMouseDown.height = box.height;
            });
        }

        canvas.addEventListener("mousedown", (event) => {
            mouseDownPosition.x = event.offsetX;
            mouseDownPosition.y = event.offsetY;
            let isMouseInBoxes = setBoxesState(true, event.offsetX, event.offsetY);
            boxes.forEach((box) => {
                box.positionWhenMouseDown.x = box.x;
                box.positionWhenMouseDown.y = box.y;
                box.sizeWhenMouseDown.width = box.width;
                box.sizeWhenMouseDown.height = box.height;
            });

            // 如果都沒點到框，則為圖片拖曳模式
            if (!isMouseInBoxes) {
                imgProps.isDragging = false; // 禁用圖片拖曳
            }
        });

        canvas.addEventListener("mousemove", (event) => {
            if (state.scanType === "precise") {
                setBoxesState(false, event.offsetX, event.offsetY);
            }
            if (imgProps.isDragging) {
                let dx = event.offsetX - mouseDownPosition.x;
                let dy = event.offsetY - mouseDownPosition.y;
                imgProps.x += dx;
                imgProps.y += dy;
                mouseDownPosition.x = event.offsetX;
                mouseDownPosition.y = event.offsetY;
                drawImage();
            } else {
                setBoxesPositionAndSize(event.offsetX, event.offsetY);
                drawImage();
            }
        });

        canvas.addEventListener("mouseup", () => {
            imgProps.isDragging = false;
            clearBoxesState();
        });

        const state = new Proxy({
            scanType: 'full'
        }, {
            set(target, key, value) {
                if (target[key] !== value) {
                    target[key] = value;
                    drawImage();
                }
                return true;
            }
        });

        function changeScanType(newType) {
            state.scanType = newType;
        }

        //切換掃描模式
        document.addEventListener("DOMContentLoaded", function () {
            const scanTypeRadios = document.querySelectorAll("input[name='type']");
            scanTypeRadios.forEach(radio => {
                radio.addEventListener("change", function () {
                    let instructions = document.getElementById("instructions");
                    let ocrTextResult = document.getElementById("ocrTextResult");
                    if (this.value === "full") {
                        instructions.style.display = "none";
                        ocrTextResult.style.display = "block";

                    } else {
                        instructions.style.display = "block";
                        ocrTextResult.style.display = "none";
                    }
                    drawImage();
                });
            });
        });

        document.querySelectorAll('input[name="type"]').forEach(radio => {
            radio.addEventListener("change", function () {
                state.scanType = this.value;
            });
        });

        // 選擇檔案按鈕2
        function selectFile2() {
            fileInput2.click();
        }

        // 檔案選擇後觸發
        function fileChange2(event) {
