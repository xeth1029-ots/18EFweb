@using (Html.BeginForm("SaveUploadDBBC", "EnterType", FormMethod.Post, htmlAttributes: new { id = "detail_form" }))
{
    @Html.Hidden("Epi")
    @Html.Hidden("Epb")
    @Html.Hidden("Ept")
    @Html.Hidden("ACID")
