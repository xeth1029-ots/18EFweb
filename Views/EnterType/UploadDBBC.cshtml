@using WDAIIP.WEB.Models
@*@model SignUpViewModel*@
@{
    ViewBag.Title = "會員專區--上傳身分證件驗證";
    ViewBag.TitleB = "上傳身分證件驗證";
    Layout = "~/Views/Shared/_MainLayout_NoClassSearch.cshtml";
    SessionModel sm = SessionModel.Get();
    int cst_PostedFile_MAX_SIZE_10M = 10485760; //10*1024*1024=10,485,760  '2 * 1024 * 1024 = 2,097,152
}

<div class="col-sm-12">
    <!-- bread start --->
    <div class="breadlink"><a title="中間主要功能選項區" accesskey="C" id="C" href="#C" style="text-decoration:none;">:::</a><i class="fa fa-home space-right" aria-hidden="true"></i>目前位置：<a href="@Url.Content("~/EnterType")" title="首頁">首頁</a> / 會員專區 / @(ViewBag.TitleB) </div>
    <!-- bread end --->
    <h3 class="main-title main-title-green"><i class="fas fa-edit space-right"></i>@(ViewBag.TitleB)</h3>
    <div style="display: none">
        @*@Html.HiddenFor(m => m.Detail.epi)*@
        <input id="Detail_epi" type="hidden" /> <input id="Detail_epb" type="hidden" /> <input id="Detail_ept" type="hidden" />
    </div>
    <!-- search form start -->
