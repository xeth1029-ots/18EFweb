@using WDAIIP.WEB.Models
@model SignUpViewModel

@{
    ViewBag.Title = "會員專區--報名資料維護";
    Layout = "~/Views/Shared/_MainLayout_NoClassSearchNoGTM.cshtml";
}

<div class="col-sm-12">
    <!-- bread start --->
    <div class="breadlink"><a title="中間主要功能選項區" accesskey="C" id="C" href="#C" style="text-decoration:none;">:::</a><i class="fa fa-home space-right" aria-hidden="true"></i>目前位置：<a href="@Url.Content("~/")" title="回首頁">首頁</a> / 會員專區 / 會員資料維護 </div>
    <!-- bread end --->
    <h3 class="main-title main-title-pink"><i class="fas fa-edit space-right"></i>會員資料維護</h3>
    <!-- search form start -->
    <div class="unit-border">
        <div class="unit-bg unit-bg-green">
            <p>本功能使用說明：</p>
            <ol>
                <li>請按下「報名資料維護」，於台灣就業通網站登入會員後，再繼續本項作業。(目前網站連線逾時為30分鐘)</li>
                <li>本方案訓練課程報名方式係開訓日前1個月，統一於本網站線上報名。招訓及遴選方式除另有規定外，以報名先後順序為準，故若首次參加本方案訓練課程之學員，請先於本區填寫報名相關資料，以利縮短後續報名作業。 </li>
                <li>本區所填資料係提供訓練單位審查學員是否具補助參訓身分。填妥本區資料不等於報名及錄訓，故欲參訓之學員仍請於課程報名期間，至【<a href="@Url.Content("~/ClassSearch")" title="前往課程查詢報名">課程查詢報名</a>】完成報名程序。 </li>
                <li>曾經參訓者，將由系統自動帶入您前次報名時所填寫之資料，若有變動，請於報名前至本區更新。另部分基本資料內容修正為灰階，民眾如欲修正請至台灣就業通個人會員資料維護。 </li>
                <li>報名資料維護不溯及已報名之課程，若需變更【<a href="@Url.Content("~/ClassSearch")" title="前往課程查詢報名">課程查詢報名</a>】當下所送出之資料，請逕洽訓練單位更正。 </li>
            </ol>
        </div>
        <div class="clearfix"></div>
        @using (Html.BeginForm("Detail", "EnterType", FormMethod.Post, htmlAttributes: new { id = "main_form", @class = "form-horizontal" }))
        {
            @Html.HiddenFor(m => m.Form.NAME)
            @Html.HiddenFor(m => m.Form.BIRTH_MON)
            @Html.HiddenFor(m => m.Form.BIRTH_DAY)
            @Html.HiddenFor(m => m.Form.IDNO)
            <div class="form-group-search">
                @Html.CustomLabelFor(m => m.Form.NAME, new { @class = "form-label-search" })
                <div class="form-input">
                    @Html.TextBoxFor(m => m.Form.NAME_MK, new { @class = "form-control form-50", placeholder = "姓名", title = "姓名" }, true)
                </div>
            </div>
            <div class="form-group-search">
                <label for="Form_BIRTH_YEAR" class="form-label-search">出生日期</label>
                <div class="form-input form-inline">
                    <label for="Form_BIRTH_YEAR">民國</label>
                    @Html.TextBoxFor(m => m.Form.BIRTH_YEAR, new { @class = "form-control", placeholder = "年", maxlength = 3, size = 4, title = "出生日期年" }, true)
                    <label for="Form_BIRTH_YEAR">年</label>
                    @Html.TextBoxFor(m => m.Form.DOUBLESTAR, new { @class = "form-control", placeholder = "月", maxlength = 2, size = 3, title = "出生日期月" }, true)
                    <label for="Form_BIRTH_MON">月</label>
                    @Html.TextBoxFor(m => m.Form.DOUBLESTAR, new { @class = "form-control", placeholder = "日", maxlength = 2, size = 3, title = "出生日期日" }, true)
                    <label for="Form_BIRTH_DAY">日</label>
                </div>
            </div>
            <div class="form-group-search">
                @Html.CustomLabelFor(m => m.Form.IDNO, new { @class = "form-label-search" })
                <div class="form-input">
                    @Html.TextBoxFor(m => m.Form.IDNO_MK, new { @class = "form-control", placeholder = "身分證號", maxlength = 10, title = "身分證號" }, true)
                </div>
            </div>
            <div class="form-group-search"> </div>
            <div class="clearfix"></div>
            <div class="submit-bar">
                <button type="button" data-role="SendData" class="btn-orange" title="報名資料維護">報名資料維護</button>
                <button type="button" data-role="GoDetail" class="btn-refill" title="取消">取消</button>
            </div>
        }
        <p>
        <p>
            <!-- search form end -->
    </div>
</div>

<script type="text/javascript">
    $(function () {
        //報名資料維護鈕
        $("button[data-role='SendData']").on("click", function () {
            var url = '@Url.Action("StopEnterTempMsg", "Ajax")';
            var data = {};

            //先查詢是否有設定停止報名設定，有則要先顯示停止報名訊息
            ajaxLoadMore(url, data, function(resp) {
                if (resp === undefined || resp.data == null || resp.data == "") {
                    CheckBlackList();
                } else {
                    blockAlert(resp.data, "提示訊息", function () {
                        CheckBlackList();
                    });
                }
            });
        });
    });

    //檢核黑名單
    function CheckBlackList() {
        var url = '@Url.Action("CheckBlackList", "Ajax")';
        var data = {};
        var form = $("#main_form");
        var msg = "";

        ajaxLoadMore(url, data, function (resp) {
            if (resp === undefined) {
            } else {
                if (resp.status) {
                    msg = "填寫基本資料時，請務必填寫可以聯繫到您本人的資料，方便訓練單位與您聯繫!!<br>";
                    msg += "目前系統時間為(" + resp.data + ")";
                    blockAlert(msg, "", function () {
                        form.submit();
                    });
                } else {
                    blockAlert(resp.data, "", function () { return false; });
                    return false;
                }
            }
        });
    }
</script>
