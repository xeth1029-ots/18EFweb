@model WDAIIP.WEB.Models.ClassConfirm003ViewModel

@if (Model.DistNameGrid_list != null && Model.DistNameGrid_list.Count > 0)
{
    for (int i = 0; i < Model.DistNameGrid_list.Count; i++)
    {
        var item = Model.DistNameGrid_list[i];

        if ((Model.Form.DISTID).Equals(item.DISTID))
        {
            <li><a id="aDistID_@(item.DISTID)" href="javascript:doqueryClassConfirm003Class('@item.DISTID')" class="active" title="@item.DISTNAME">@item.DISTNAME</a></li>
        }
        else
        {
            <li><a id="aDistID_@(item.DISTID)" href="javascript:doqueryClassConfirm003Class('@item.DISTID')" title="@item.DISTNAME">@item.DISTNAME</a></li>
        }
    }
}
else
{
    <div> 查無資料 </div>
}
