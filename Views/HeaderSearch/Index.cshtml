        @*doChangeCondition('@Model.Form.PlanType');*@
        var planType = '@Model.Form.PlanType';

        if (planType != "") {
            @*2019-02-23 無障礙修正：8.3如果網頁能依序導覽，且導覽順序將會影響到意義或操作，則可取得焦點的元件要以能保留意義與操作性的順序，來取得焦點。
