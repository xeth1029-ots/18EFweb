@model WDAIIP.WEB.Models.HomeViewModel

<div class="col-sm-12">
    @using (Html.BeginForm("Index", "ClassSearch", FormMethod.Post, new { id = "main_form" }))
    {
        @Html.HiddenFor(m => m.Form.IsHomeSearch)
        @Html.HiddenFor(m => m.Form.IsContainsOverEnter)
        <div class="search-bar">
            <div class="search_select">
                <div id="condition" class="search_select">
                    @Html.Partial("_Condition", Model)
                </div>
                <div class="search_btn">
                    <button type="submit" name="btnSch" value="查詢" id="btnSch" class="btn_set" title="查詢">查詢</button>
                </div>
            </div>
            <div class="search_select">
                <span color="red">*產業人才投資方案，快速搜尋課程區間預設為最近3個月之開訓課程，查詢後欲看更多課程，請點選「修改查詢條件」按鍵。</span>
            </div>
        </div>
    }
</div>
<script type="text/javascript">
