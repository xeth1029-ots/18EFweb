            /*doChangePlan(planType);*/
        }
    });
    /*切換計畫類別條件*/
    function doChangePlan(plantype) {
        var url = '@Url.Action("GetCondition","HeaderSearch")';
        var data = { PlanType: plantype, keywords: $("#Form_KEYWORDS").val() };

        ajaxLoadMore(url, data, function (resp) {
            $('#condition').html(resp);
            /*修改無障礙：EV1080300：按照內容的序列及關連性來安排互動元件的放置順序,fix 切換計畫別下拉選項後focus狀態會跑掉問題,*/
            $("select#Form_PlanType").focus();
        });
    }
