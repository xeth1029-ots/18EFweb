<!--回明細頁-->
@using (Html.BeginForm("Detail", "ClassSearch", FormMethod.Post, htmlAttributes: new { id = "GoDetailForm" }))
{
    @Html.Hidden("PlanType", Model.Form.PlanType)
    @Html.Hidden("ProvideLocation", Model.Form.ProvideLocation)
    @Html.Hidden("OCID", Model.Form.OCID)
}

<script type="text/javascript">
    $(document).ready(function () {
        // 時間倒數
        // window.setTimeout('show_secs()', 1);

        //if ($('#hid_ZIPCODE_2W').val() != "") {
        //    $('#Detail_ZIPCODE_2W').val($('#hid_ZIPCODE_2W').val());
        //    $('#hid_ZIPCODE_2W').val("");
        //}
        //if ($('#hid_ZIPCODE2_2W').val() != "") {
        //    $('#Detail_ZIPCODE2_2W').val($('#hid_ZIPCODE2_2W').val());
        //    $('#hid_ZIPCODE2_2W').val("");
        //}
        //if ($('#hid_ZIPCODE3_2W').val() != "") {
        //    $('#Detail_ZIPCODE3_2W').val($('#hid_ZIPCODE3_2W').val());
        //    $('#hid_ZIPCODE3_2W').val("");
        //}
        $('#Detail_MIDENTITYID').change(function () {
            if ($('#Detail_ACTTYPE').val() != '4' && $('#Detail_ACTTYPE').val() != '') {
                $('#hid_Detail_ACTTYPE_VAL1').val($('#Detail_ACTTYPE').val());//保留
            }
            if ($(this).val() == '43') {
                $('#Detail_ACTTYPE').val('4'); //4.軍;//設定
            } else if ($(this).val() != '43') {
                $('#Detail_ACTTYPE').val($('#hid_Detail_ACTTYPE_VAL1').val()); //重設定
            }
            var fg_lock1 = ($(this).val() == '43' && $('#Detail_ACTTYPE').val() == '4');
            $('#Detail_ACTTYPE').prop('disabled', fg_lock1); // 鎖定/解鎖
        });

        // 會員基本資料-所有欄位不可編輯（radio,select）
        $("div[id^='mem_']").find("input").each(function () {
            $(this).attr("disabled", true);
        });
        $("select[id^='mem_']").each(function () {
            $(this).attr("disabled", true);
        });
        $("input[id^='mem_']").each(function () {
            $(this).attr("disabled", true);
        });

        //GetZipName 取得 縣市轄區中文 查詢郵遞區號
        $("input[data-role='zipcode']").blur(function () {
            var zipcode = $(this).val();
            var datacity = $(this).attr("data-city");

            var url = '@Url.Action("GetZipName", "Ajax")';
            var data = { zipcode: zipcode };

            ajaxLoadMore(url, data, function (resp) {
                if (!(resp === undefined)) {
                    if (resp.data == null || resp.data == "") {
                        $("#" + datacity).val("");
                    } else {
                        $("#" + datacity).val(resp.data);
                    }
                }
            });
        });

        //送出報名資料 SaveData
        $("button[data-role=SaveData]").on("click", function () {
            const $btn = $(this);
            const $form = $("form#main_form");

            // 1. 前端初步驗證 (提升效能：減少無效的 AJAX 請求)
            const isPlan28 = '@Model.Detail.ISPLAN28';
            const isCheck1 = $('input[name="Detail.ISCHECK"]:checked').val();
            const isAgree = $('input[name="Detail.ISAGREE"]:checked').val();
            const isCheck2 = $('input[name="Detail.ISCHECK2"]:checked').val();
            var blockMsg1 = "";
            if (isPlan28 === "Y") {
                if ($('input[name="Detail.ISCHECK"]').length > 0 && isCheck1 !== "Y") blockMsg1 += "*本人「確認」於開訓當日為具就業保險、勞工保險或農民保險被保險人身分之在職勞工。如不符補助參訓資格，同意於繳費後，依退費相關規定辦理。才能報名。\n";
            }
            if (isAgree !== "Y") blockMsg1 += "*本人已充分獲知且瞭解上述事項「同意」個人資料蒐集條款。才能報名\n"; //return;
            if (isCheck2 !== "Y") blockMsg1 += "*本人「確認」上述為個人最新及正確資料。才能報名\n"; //return;
            if (blockMsg1 != "") {
                blockAlert(blockMsg1, "提示訊息");
                return;
            }
            // 2. 解鎖欄位以便送出資料
            $('#Detail_ACTTYPE').prop('disabled', false);
            const url = "@Url.Action("GetSysDate","Ajax")";
            //const isPlan28 = '@Model.Detail.ISPLAN28';
            const vPlanType = '@Model.Form.PlanType';

            // 3. 執行送出流程
            ajaxLoadMore(url, {}, function (resp) {
                let msg = "資料確認無誤，確定送出？";
                if (resp && resp.data) { msg += "<br>目前系統時間為(" + resp.data + ")"; }

                blockConfirm(msg, "提示訊息", function () {
                    // 防止重複點擊
                    $btn.prop("disabled", true);
                    // 4. 動態路由決定
                    if (isPlan28 === "N") {
                        if (vPlanType === "2") {
                            $form.attr("action", '@Url.Action("SignUp06", "SignUp")');
                        } else if (vPlanType === "5") {
                            $form.attr("action", '@Url.Action("SignUp70", "SignUp")');
                        }
                    }
                    $form.submit();
                });
            });
        });

        //回查詢清單 GoList
        $("a[data-role=GoList]").click(function () {
            $("form#GoListForm").submit();
        });

        //回明細頁 GoDetail
        $("a[data-role=GoDetail]").click(function () {
            $("form#GoDetailForm").submit();
        });

        $("button[data-role=GoDetail]").click(function () {
            $("form#GoDetailForm").submit();
        });

        //取消鈕
        $("button[data-role=GoBack]").click(function () {
            var isPlan28 = '@Model.Detail.ISPLAN28';
            var isOnlineSignUp = '@sm.IsOnlineSignUp';
            var actionName = "";

            if (isPlan28 == "Y") {
                actionName = '@Url.Action("Index", "SignUp")';
            } else {
                if (isOnlineSignUp == "Y") {
                    //回到線上報名-課程代碼查詢頁
                    actionName = '@Url.Action("Online1", "SignUp")';
                } else {
                    //回課程明細頁
                    actionName = '@Url.Action("Detail", "ClassSearch")';
                }
            }
            blockConfirm("資料未存檔，確定離開此網頁 ?！", "", function () {
                $("form#GoDetailForm").attr("action", actionName).submit();
            })
        });

        //是否有行動電話 選取改變事件
        $('input[name="Detail.HASMOBILE"]').on("change", function () {
            if ($(this).val() == "Y")
                $("#Detail_CELLPHONE").attr("disabled", false);
            else
                $("#Detail_CELLPHONE").attr("disabled", true);
        });

        //是否有email 選取改變事件
        $('input[name="Detail.HASEMAIL"]').on("change", function () {
            if ($(this).val() == "Y")
                $("#Detail_EMAIL").attr("disabled", false);
            else
                $("#Detail_EMAIL").attr("disabled", true);
        });


        // 切換郵政/銀行帳號選項，顯示各自對應的帳號填寫表單資訊
        $('input[id^="rdo_ACCTMODE"]').on("change", function () {
            var rdoVal = $(this).val();
            doShowAcctForm(rdoVal);
        });

        // 填寫勞保證號提示訊息
        $("a[data-role='ACTNO_MSG']").on("click", function () {
            var msg = "請依勞保明細表確實填寫。<br>";
            msg += "另參加職前訓練期間，接受政府訓練經費補助者<br>";
            msg += "(勞保投保證號前2碼數字為09訓字保之參訓學員)<br>";
            msg += "，及勞保明細表為裁字保之參訓學員，不予補助訓練費用。";

            blockAlert(msg, "提示訊息", function () { });
        });

        // 判斷是要顯示銀行or郵局帳號填寫區
        var acctMode = '@(Model.Detail.ACCTMODE)';
        doShowAcctForm(acctMode);
    });

    // 銀行/郵局帳號填寫區顯示控制
    function doShowAcctForm(acctMode) {
        var divPost = $("#divPost");
        var divBank1 = $("#divBank1");
        var divBank2 = $("#divBank2");
        var divBank3 = $("#divBank3");

        divPost.hide();
        divBank1.hide();
        divBank2.hide();
        divBank3.hide();

        switch (acctMode) {
            case "0": //郵局
                divPost.show();
                break;
            case "1": //銀行
                divBank1.show();
                divBank2.show();
                divBank3.show();
                break;
        }
    }

    // 地址複製(通訊-->戶籍)
    function copyZip() {
        if ($("#mycheckbox").prop("checked")) {
            $('#Detail_ZIPCODE2').val($('#Detail_ZIPCODE').val());
            $('#Detail_ZIPCODE2_2W').val($('#Detail_ZIPCODE_2W').val());
            $('#Detail_ZIPCODE2_6W').val($('#Detail_ZIPCODE').val() + $('#Detail_ZIPCODE_2W').val());

            $('input[name="Detail_ZIPCODE2"]').val($('input[name="Detail_ZIPCODE"]').val());
            $('input[name="CITY2"]').val($('input[name="CITY1"]').val());
            $('#Detail_HOUSEHOLDADDRESS').val($('#Detail_ADDRESS').val());
        } else {
            $('#Detail_ZIPCODE2').val('');
            $('#Detail_ZIPCODE2_2W').val('');
            $('#Detail_ZIPCODE2_6W').val('');
            $('input[name="Detail_ZIPCODE2"]').val('');
            $('input[name="CITY2"]').val('');
            $('#Detail_HOUSEHOLDADDRESS').val('');
        }
    }

    // 郵遞區號地址資料選取對話框
    // flag: 1為通訊地址、2為戶籍地址、3.投保單位地址
    var onZipSelect;

    function doZipSelect(flag) {
        var url = '@Url.Action("Index", "Zip")';
        var title = "郵遞區號查詢";
        var arrBtn = "";
        var params = { onclickHandler: "onZipSelect" };

        // 回傳的data中包含，// zipcode:郵遞區號前三碼// zipcode2:郵遞區號後兩碼// ctname:縣市名稱// zipname:鄉鎮市區名稱// road:街道名稱
        onZipSelect = function (data) {
            if (data != undefined) {
                switch (flag) {
                    case 1:
                        $("#Detail_ZIPCODE").val(data.zipcode);
                        $("#Detail_ZIPCODE_2W").val(data.zipcode2);
                        $("#Detail_ZIPCODE_6W").val(data.zipcode + data.zipcode2);
                        $("#CITY1").val(data.ctname + data.zipname);
                        $("#Detail_ADDRESS").val(data.road);
                        break;
                    case 2:
                        $("#Detail_ZIPCODE2").val(data.zipcode);
                        $("#Detail_ZIPCODE2_2W").val(data.zipcode2);
                        $("#Detail_ZIPCODE2_6W").val(data.zipcode + data.zipcode2);
                        $("#CITY2").val(data.ctname + data.zipname);
                        $("#Detail_HOUSEHOLDADDRESS").val(data.road);
                        break;
                    case 3:
                        $("#Detail_ZIPCODE3").val(data.zipcode);
                        $("#Detail_ZIPCODE3_2W").val(data.zipcode2);
                        $("#Detail_ZIPCODE3_6W").val(data.zipcode + data.zipcode2);
                        $("#CITY3").val(data.ctname + data.zipname);
                        $("#Detail_ACTADDRESS").val(data.road);
                        break;
                }
            }
        }

        popupDialog(url, title, arrBtn, 600, params);
    }

