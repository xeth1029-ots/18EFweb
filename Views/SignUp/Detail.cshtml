@model WDAIIP.WEB.Models.SignUpViewModel
@using WDAIIP.WEB.DataLayers
@using WDAIIP.WEB.Commons
@using WDAIIP.WEB.Models

@{
    ViewBag.Title = "課程查詢報名--個人報名基本資料";
    Layout = "~/Views/Shared/_MainLayout_NoClassSearchNoGTM.cshtml";

    SessionModel sm = SessionModel.Get();
    string memMsg = "如欲修改個人基本資料，請至台灣就業通「會員中心」變更";
    string s_PostCodeQry = MyCommonUtil.Get_PostCodeQry();
}

<style type="text/css">
    .group-width input { margin-right: 8px; }
    .group-width label { margin-right: 13px; }
</style>
<div class="col-sm-12">
    <!-- bread start --->
    <div class="breadlink"><a title="中間主要功能選項區" accesskey="C" id="C" href="#C" style="text-decoration:none;">:::</a><i class="fa fa-home space-right" aria-hidden="true"></i>目前位置：<a href="@Url.Content("~/")" title="回首頁">首頁</a> / 課程查詢報名 / 課程查詢 / 線上報名</div>
    <!-- bread end --->
    <h3 class="main-title main-title-blue"><i class="fas fa-edit space-right"></i>線上報名</h3>
    <!-- note info -->
    <div class="unit-bg unit-bg-gray">
        <span>
            1. 本畫面作業完成前，請勿關閉或離開本畫面，否則必須重新登入會員並重新填寫資料。 <br />
            2. 本功能除灰色底欄位不提供修正（如欲修正請至台灣就業通<strong><a href="https://job.taiwanjobs.gov.tw/internet/jobwanted/member/member_data_m.aspx" target="_blank" rel="noreferrer noopener" title="[另開新視窗]前往台灣就業通"><span class="sr-only">(另開新視窗)</span>「會員中心」</a></strong>變更），其餘皆可自行修改。<br />
            3. 郵遞區號請填寫完整之3+2碼。<br />
        </span>
    </div>
    <!-- personal info -->
    @using (Html.BeginForm("SignUp", "SignUp", FormMethod.Post, htmlAttributes: new { id = "main_form", @class = "form-horizontal" }))
    {
        @Html.HiddenFor(m => m.Form.PlanType)
        @Html.HiddenFor(m => m.Form.ProvideLocation)
        @Html.HiddenFor(m => m.Form.OCID)
        @*產投跟在職的資料都是在stud_entertemp3，當「主要參訓身份別」有寫入資料表示是在維護產投報名資料*@
        @Html.HiddenFor(m => m.Detail.OCID)
        @Html.HiddenFor(m => m.Detail.DB3D0C)
        @Html.HiddenFor(m => m.Detail.IsSignUp)
        @Html.HiddenFor(m => m.Detail.ESETID3)
        @Html.HiddenFor(m => m.Detail.ISPLAN28)
        @Html.HiddenFor(m => m.Detail.STDATE)

        <div class="unit-border">
            <h3 class="titlebar titlebarBg-green">個人報名基本資料</h3>
            <div class="form-group-search">
                <label for="Detail_CLASSCNAME" class="form-label-data"><span class="text-danger">*</span> 課程名稱</label>
                <div class="form-input-dataHelf-3">
                    @Html.TextBoxFor(m => m.Detail.CLASSCNAME, new { @class = "form-control", placeholder = "", @readonly = true, title = @memMsg })
                </div>
            </div>
            <div class="form-group-search">
                <label for="Detail_NAME" class="form-label-data"><span class="text-danger">*</span> 中文姓名</label>
                <div class="form-input-dataHelf">
                    @Html.HiddenFor(m => m.Detail.NAME3)
                    @Html.TextBoxFor(m => m.Detail.NAME, new { @class = "form-control", placeholder = "", @readonly = true, title = @memMsg, maxlength = "20" })
                </div>
            </div>
            <div class="form-group-search">
                <label for="Detail_PASSPORTNO_1" class="form-label-data"><span class="text-danger">*</span> 身分別</label>
                <div class="form-input-dataHelf form-inline">
                    @Html.HiddenFor(m => m.Detail.PASSPORTNO)
                    @Html.RadioGroupFor(m => m.Detail.PASSPORTNO, Model.PASSPORTNO_list, new { @class = "group-width", id = "mem_passportno", title = @memMsg })
                </div>
                <label for="Detail_IDNO" class="form-label-data"><span class="text-danger">*</span> 身分證字號</label>
                <div class="form-input-dataHelf">
                    @Html.TextBoxFor(m => m.Detail.IDNO, new { @class = "form-control", placeholder = "", @readonly = true, title = @memMsg, maxlength = "13" })
                </div>
            </div>
            <div class="form-group-search">
                <label for="Detail_SEX_M" class="form-label-data"><span class="text-danger">*</span> 性 別</label>
                <div class="form-input-dataHelf form-inline">
                    @Html.HiddenFor(m => m.Detail.SEX)
                    @Html.RadioGroupFor(m => m.Detail.SEX, Model.SEX_list, new { @class = "group-width", id = "mem_sex", title = @memMsg })
                </div>
                <label for="Detail_BIRTHDAY_TW" class="form-label-data"><span class="text-danger">*</span> 出生日期</label>
                <div class="form-input-dataHelf form-inline">
                    @Html.HiddenFor(m => m.Detail.BIRTHDAY)
                    @Html.TextBoxFor(m => m.Detail.BIRTHDAY_TW, new { @class = "form-control", placeholder = "", @readonly = true, title = @memMsg })
                </div>
            </div>
            <div class="form-group-search">
                <label for="mem_DEGREEID" class="form-label-data"><span class="text-danger">*</span> 最高學歷</label>
                <div class="form-input-dataHelf">
                    @Html.HiddenFor(m => m.Detail.DEGREEID)
                    @Html.DropDownListFor(m => m.Detail.DEGREEID, Model.DEGREEID_list, "請選擇", new { @class = "form-control", id = "mem_DEGREEID", title = @memMsg })
                </div>
                <label for="Detail_GRADID_01" class="form-label-data"><span class="text-danger">*</span> 畢業狀況</label>
                <div class="form-input-dataHelf form-inline">
                    @*Html.HiddenFor(m => m.Detail.GRADID)*@
                    @Html.RadioGroupFor(m => m.Detail.GRADID, Model.GRADID_list, new { @class = "group-width" })
                </div>
            </div>
            <div class="form-group-search">
                <label for="Detail_SCHOOLNAME" class="form-label-data"><span class="text-danger">*</span> 學校名稱</label>
                <div class="form-input-dataHelf">
                    @Html.TextBoxFor(m => m.Detail.SCHOOLNAME, new { @class = "form-control", placeholder = "請輸入學校名稱", title = "請輸入學校名稱", MaxLength = "30" })
                </div>
                <label for="Detail_DEPARTMENT" class="form-label-data"><span class="text-danger">*</span> 科系名稱</label>
                <div class="form-input-dataHelf">
                    @Html.TextBoxFor(m => m.Detail.DEPARTMENT, new { @class = "form-control", placeholder = "請輸入科系名稱", title = "請輸入科系名稱", MaxLength = "120" })
                </div>
            </div>
            <div class="form-group-search">
                <label for="mem_MARITALSTATUS" class="form-label-data">婚姻狀況</label>
                <div class="form-input-dataHelf">
                    @Html.HiddenFor(m => m.Detail.MARITALSTATUS)
                    @Html.DropDownListFor(m => m.Detail.MARITALSTATUS, Model.MARITALSTATUS_list, new { @class = "form-control", id = "mem_MARITALSTATUS", title = @memMsg })
                </div>
            </div>
            <div class="form-group-search">
                <label for="Detail_PHONED" class="form-label-data"><span class="text-danger">*</span> 聯絡電話</label>
                <div class="form-input-dataHelf">
                    <div class="form-inline">
                        <p> (日)@Html.TextBoxFor(m => m.Detail.PHONED, new { @class = "form-control", placeholder = "請輸入聯絡電話(日)", title = "請輸入聯絡電話(日)", MaxLength = "13" })</p>
                    </div>
                    <div class="form-inline">
                        (夜)@Html.TextBoxFor(m => m.Detail.PHONEN, new { @class = "form-control", placeholder = "請輸入聯絡電話(夜)", title = "請輸入聯絡電話(夜)", MaxLength = "13" })<br /><label style="font-weight:normal; color:red;">聯絡電話僅可輸入數字或插入「-」符號</label>
                    </div>
                </div>
                <label for="HASMOBILE_N" class="form-label-data"><span class="text-danger">*</span> 行動電話</label>
                <div class="form-input-dataHelf form-inline group-width">
                    @*@Html.HiddenFor(m => m.Detail.HASMOBILE)*@
                    @Html.RadioButtonFor(m => m.Detail.HASMOBILE, "N", new { id = "HASMOBILE_N", title = "請選擇是否有行動電話" })
                    <label style="font-weight:normal; cursor:pointer" for="HASMOBILE_N">無</label>
                    @Html.RadioButtonFor(m => m.Detail.HASMOBILE, "Y", new { id = "HASMOBILE_Y", title = "請選擇是否有行動電話" })
                    <label style="font-weight:normal; cursor:pointer" for="HASMOBILE_Y">有</label>
                    @Html.TextBoxFor(m => m.Detail.CELLPHONE, new { @class = "form-control", placeholder = "請輸入行動電話", title = "請輸入行動電話", MaxLength = "13" })<br /><label style="font-weight:normal; color:red;">行動電話僅可輸入數字10碼</label>
                </div>
            </div>
            <div class="form-group-search">
                <label for="Detail_ZIPCODE" class="form-label-data"><span class="text-danger">*</span> 通訊地址</label>
                <div class="form-input-data form-inline">
                    <button type="button" id="btnSchZip" class="btn btn-info" onclick="doZipSelect(1)" title="查詢郵遞區號">...</button>
                    @Html.TextBoxFor(m => m.Detail.ZIPCODE, new { @class = "form-normal", size = "3", maxlength = "3", @data_role = "zipcode", @data_city = "CITY1", title = "郵遞區號(前3碼)" })-
                    @Html.HiddenFor(m => m.Detail.ZIPCODE_6W)
                    @Html.TextBoxFor(m => m.Detail.ZIPCODE_2W, new { @class = "form-normal", size = "3", maxlength = "3", title = "郵遞區號(後2碼或3碼)" })
                    @Html.Raw(s_PostCodeQry)
                    @*<a href="@s_PostCodeQry" target="_blank" title="前往查詢3+2郵遞區號(另開新視窗)">(3+2郵遞區號查詢)</a>*@
                    @if (!string.IsNullOrEmpty(Convert.ToString(Model.Detail.ZIPCODE)))
                    {
                        var strCityZame = (new MyKeyMapDAO()).GetZipName2(Convert.ToString(Model.Detail.ZIPCODE));
                        <input name="CITY1" type="text" class="form-control" id="CITY1" onfocus="this.blur();" value="@strCityZame" title="縣市區域">
                    }
                    else
                    {
                        <input name="CITY1" type="text" class="form-control" id="CITY1" onkeydown="this.blur()" oncontextmenu="return false;" title="縣市區域">
                    }
                    @Html.TextBoxFor(m => m.Detail.ADDRESS, new { @class = "form-control", size = "70", maxlength = "120", placeholder = "請輸入通訊地址", title = "請輸入通訊地址" })
                </div>
            </div>
            <div class="form-group-search">
                <label for="HASEMAIL_N" class="form-label-data"><span class="text-danger">*</span> 電子郵件</label>
                <div class="form-input-data form-inline group-width">
                    @*@Html.HiddenFor(m => m.Detail.HASEMAIL)*@
                    @Html.RadioButtonFor(m => m.Detail.HASEMAIL, "N", new { id = "HASEMAIL_N", title = "請選擇是否有電子信箱" })
                    <label style="font-weight:normal; cursor:pointer" for="HASEMAIL_N">無</label>

                    @Html.RadioButtonFor(x => x.Detail.HASEMAIL, "Y", new { id = "HASEMAIL_Y", title = "請選擇是否有電子信箱" })
                    <label style="font-weight:normal; cursor:pointer" for="HASEMAIL_Y">有</label>

                    @Html.TextBoxFor(m => m.Detail.EMAIL, new { @class = "form-control", size = "70", placeholder = "請輸入電子郵件信箱", title = "請輸入電子郵件信箱", MaxLength = "60" })
                </div>
            </div>
            <p>
                <br />
                <div class="unit-bg unit-bg-green unit-spaces">
                    <strong><label style="color:red;">請務必填入可聯繫到本人之電話或電子郵件，倘因填寫錯誤或未填，致訓練單位無法通知錄訓繳費或甄試，須自負其責。</label></strong>
                </div>
            </p>
            <div class="form-group-search">
                <label for="Detail_MIDENTITYID" class="form-label-data"><span class="text-danger">*</span> 主要參訓身份別</label>
                <div class="form-input-dataHelf">
                    @Html.DropDownListFor(m => m.Detail.MIDENTITYID, Model.MIdentityID_list, "請選擇", new { @class = "form-control", title = "請選擇主要參訓身份別" })
                </div>
            </div>
            <div class="form-group-search">
                <label for="Detail_ZIPCODE2" class="form-label-data"><span class="text-danger">*</span> 戶籍地址</label>
                <div class="form-input-data">
                    <div class="checkbox"><label><input name="mycheckbox" id="mycheckbox" type="checkbox" onclick="copyZip()" value="" title="請勾選是否同通訊地址">同通訊地址 </label></div>
                    <button type="button" class="btn btn-info" onclick="doZipSelect(2)" title="查詢郵遞區號">...</button>
                    @Html.TextBoxFor(m => m.Detail.ZIPCODE2, new { @class = "form-normal", size = "3", maxlength = "3", @data_role = "zipcode", @data_city = "CITY2", title = "郵遞區號(前3碼)" })
                    @Html.HiddenFor(m => m.Detail.ZIPCODE2_6W)
                    @Html.TextBoxFor(m => m.Detail.ZIPCODE2_2W, new { @class = "form-normal", size = "3", maxlength = "3", title = "郵遞區號(後2碼或3碼)" })
                    @Html.Raw(s_PostCodeQry)
                    @*<a href="@s_PostCodeQry" target="_blank" title="前往查詢3+2郵遞區號(另開新視窗)">(3+2郵遞區號查詢)</a>*@
                    @if (!string.IsNullOrEmpty(Convert.ToString(Model.Detail.ZIPCODE2)))
                    {
                        var strCityZame = (new MyKeyMapDAO()).GetZipName2(Convert.ToString(Model.Detail.ZIPCODE2));
                        <input name="CITY2" type="text" class="form-normal" id="CITY2" disabled="disabled" value="@strCityZame" title="縣市區域">
                    }
                    else
                    {
                        <input name="CITY2" type="text" class="form-normal" id="CITY2" onkeydown="this.blur()" oncontextmenu="return false;" title="縣市區域">
                    }

                    @Html.TextBoxFor(m => m.Detail.HOUSEHOLDADDRESS, new { @class = "form-normal", size = "70", maxlength = "120", placeholder = "請輸入戶籍地址", title = "請輸入戶籍地址" })
                </div>
            </div>
            <div class="clearfix"></div>
            <!-- 服務單位資料 -->
            <h3 class="titlebar titlebar-lightBlue">服務單位資料</h3>
            <div class="form-group-search">
                <label for="Detail_UNAME" class="form-label-data"><span class="text-danger">*</span> 服務單位</label>
                <div class="form-input-dataHelf">
                    @Html.TextBoxFor(m => m.Detail.UNAME, new { @class = "form-control", Maxlength = "50", placeholder = "請輸入服務單位名稱", title = "請輸入服務單位名稱" })
                </div>
                <label for="Detail_INTAXNO" class="form-label-data">統一編號</label>
                <div class="form-input-dataHelf">
                    @Html.TextBoxFor(m => m.Detail.INTAXNO, new { @class = "form-control", Maxlength = "10", placeholder = "請輸入統一編號", title = "請輸入統一編號" })
                </div>
            </div>
            <div class="form-group-search">
                <label for="Detail_SERVDEPTID" class="form-label-data"><span class="text-danger">*</span> 服務部門</label>
                <div class="form-input-dataHelf">
                    @Html.DropDownListFor(m => m.Detail.SERVDEPTID, Model.Servdept_list, "請選擇", new { @class = "form-control", title = "請選擇服務部門" })
                </div>
            </div>
            <div class="form-group-search">
                <label for="Detail_ACTNAME" class="form-label-data"><span class="text-danger">*</span> 投保單位名稱</label>
                <div class="form-input-dataHelf">
                    @Html.TextBoxFor(m => m.Detail.ACTNAME, new { @class = "form-control", placeholder = "請輸入投保單位名稱", Maxlength = "50", title = "請輸入投保單位名稱" })
                </div>
                <label for="Detail_ACTTYPE" class="form-label-data"><span class="text-danger">*</span> 投保類別</label>
                <div class="form-input-dataHelf">
                    @Html.DropDownListFor(m => m.Detail.ACTTYPE, Model.ActType_List(), "請選擇", new { @class = "form-control", title = "請選擇投保類別" })
                    <input type="hidden" id="hid_Detail_ACTTYPE_VAL1" />
                </div>
            </div>
            <div class="form-group-search">
                <label for="Detail_ACTNO" class="form-label-data"> 投保單位保險證號</label>
                <div class="form-input-data">
                    @Html.TextBoxFor(m => m.Detail.ACTNO, new { @class = "form-normal", placeholder = "請輸入投保單位保險證號", Maxlength = "20", title = "請輸入投保單位保險證號" })
                    <a href="javascript:void(0)" data-role="ACTNO_MSG" title="請依勞保明細表填寫"> 請依勞保明細表確實填寫，可自行填寫，如未填寫將由系統自行代入。詳細說明內容，請點這邊...</a>
                </div>
            </div>
            <div class="form-group-search">
                <label for="Detail_ACTTEL" class="form-label-data">投保單位電話</label>
                <div class="form-input-dataHelf">
                    @Html.TextBoxFor(m => m.Detail.ACTTEL, new { @class = "form-control", placeholder = "請輸入投保單位電話", Maxlength = "30", title = "請輸入投保單位電話" })<label style="font-weight:normal; color:red;">投保單位電話僅可輸入數字或插入「-」符號</label>
                </div>
            </div>
            <div class="form-group-search">
                <label for="Detail_ZIPCODE3" class="form-label-data">投保單位地址</label>
                <div class="form-input-data">
                    <button type="button" class="btn btn-info" onclick="doZipSelect(3)" title="查詢郵遞區號">...</button>
                    @Html.TextBoxFor(m => m.Detail.ZIPCODE3, new { @class = "form-normal", size = "3", maxlength = "3", @data_role = "zipcode", @data_city = "CITY3", title = "郵遞區號(前3碼)" })
                    @Html.HiddenFor(m => m.Detail.ZIPCODE3_6W)
                    @Html.TextBoxFor(m => m.Detail.ZIPCODE3_2W, new { @class = "form-normal", size = "3", maxlength = "3", title = "郵遞區號(後2碼或3碼)" })
                    @Html.Raw(s_PostCodeQry)
                    @*<a href="@s_PostCodeQry" target="_blank" title="前往查詢3+2郵遞區號(另開新視窗)">(3+2郵遞區號查詢)</a>*@
                    @if (!string.IsNullOrEmpty(Convert.ToString(Model.Detail.ZIPCODE3)))
                    {
                        var strCityZame = (new MyKeyMapDAO()).GetZipName2(Convert.ToString(Model.Detail.ZIPCODE3));
                        <input name="CITY3" type="text" class="form-normal" id="CITY3" disabled="disabled" value="@strCityZame" title="縣市區域">
                    }
                    else
                    {
                        <input name="CITY3" type="text" class="form-normal" id="CITY3" onkeydown="this.blur()" oncontextmenu="return false;" title="縣市區域">
                    }
                    @Html.TextBoxFor(m => m.Detail.ACTADDRESS, new { @class = "form-normal", size = "70", maxlength = "120", placeholder = "請輸入投保單位地址", title = "請輸入投保單位地址" })
                </div>
            </div>
            <div class="form-group-search">
                <label for="Detail_JOBTITLEID" class="form-label-data"><span class="text-danger">*</span> 職務</label>
                <div class="form-input-dataHelf">
                    @Html.DropDownListFor(m => m.Detail.JOBTITLEID, Model.JobTitle_list, "請選擇", new { @class = "form-control", title = "請選擇職務" })
                </div>
            </div>

            <div class="clearfix"></div>
            @*要報名產投課程的才會顯示*@
            @if ("Y".Equals(Model.Detail.ISPLAN28))
            {
                @*<h3 class="titlebar titlebarBg-green">產業人才投資方案報名資料</h3>*@
                @*<div class="form-group-search">
                        <label for="Detail_PRIORWORKPAY" class="form-label-data">受訓前薪資</label>
                        <div class="form-input-dataHelf">
                            @Html.TextBoxFor(m => m.Detail.PRIORWORKPAY, new { @class = "form-control", placeholder = "請輸入受訓前薪資", maxlength = "10", title = "請輸入受訓前薪資" })
                        </div>
                    </div>*@
                <div class="form-group-search">
                    <label for="rdo_ACCTMODE_0" class="form-label-data"> 郵政/銀行帳號</label>
                    <div class="form-input-dataHelf" title="(每次重新點選)">
                        <label class="radio-inline">
                            @Html.RadioButtonFor(m => m.Detail.ACCTMODE, "0", new { @class = "form-inline radioset", id = "rdo_ACCTMODE_0", title = "請選擇郵政/銀行帳號類型(每次重新點選)" })
                            <label style="font-weight:normal; cursor:pointer" for="rdo_ACCTMODE_0">郵局帳號</label><br />
                        </label>
                        <label class="radio-inline">
                            @Html.RadioButtonFor(m => m.Detail.ACCTMODE, "1", new { @class = "form-inline radioset", id = "rdo_ACCTMODE_1", title = "請選擇郵政/銀行帳號類型(每次重新點選)" })
                            <label style="font-weight:normal; cursor:pointer" for="rdo_ACCTMODE_1">銀行帳號</label>
                        </label>
                    </div>
                </div>
                <div id="divPost" class="form-group-search" style="display:none">
                    <label for="Detail_POSTNO" class="form-label-data">局號</label>
                    <div class="form-input-dataHelf">
                        @Html.TextBoxFor(m => m.Detail.POSTNO, new { @class = "form-control", Maxlength = "10", placeholder = "請輸入局號", title = "請輸入局號" })
                    </div>
                    <label for="Detail_POST_ACCTNO" class="form-label-data">帳號</label>
                    <div class="form-input-dataHelf">
