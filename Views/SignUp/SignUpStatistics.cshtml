        var x = statistics.current + 1;
        var dataRows = [];
        while (i < statistics.data.length - 1) {
            x = getNextX(x);
            dataRows[i] = [String(x), statistics.data[x].AvgWaitTime];
            i++;
        }
        //console.log(dataRows);
        data.addRows(dataRows);
        var options = {
            title: '等待時間(毫秒)',
            width: 500,
            height: 150,
            titleTextStyle: { fontSize: 14 },
            legend: { position: 'none' },
            colors: ['#900']
        };

        var div = document.getElementById("waitTimes")
        var chart = new google.visualization.LineChart(div);

        chart.draw(data, options);
    }

    /*等待人數*/
