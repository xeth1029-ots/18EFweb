        chart.draw(data, options);
    }
</script>
<div class="col-md-12" style="text-align: center">
    <!-- 統計表格/圖型 顯示用 container-->
    <div style="width: 1024px">
        <div id="processTimes" style="margin: 5px; float: left"></div>
        <div id="waitTimes" style="margin: 5px; float: right"></div>
    </div>
    <div style="width: 1024px">
        <div id="waitCount" style="margin: 5px; float: left"></div>
        <div id="timeoutCount" style="margin: 5px; float: right"></div>
    </div>
    <div style="width: 1024px">
        <div id="successCount" style="margin: 5px; float: left"></div>
        <div id="failCount" style="margin: 5px; float: right"></div>
    </div>

</div>



