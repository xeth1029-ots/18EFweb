@using (Html.BeginForm("Online1", "SignUp", FormMethod.Get, new { id = "GoOnline1Form" }))
{

}

<script type="text/javascript">
    $(document).ready(function () {
        // 預先快取常用物件
        const $signUpBtn = $("button[data-role=GoSignUp]");
        const $mainForm = $("#main_form");

        // 報名按鈕事件
        $signUpBtn.on("click", function () {
            const $this = $(this);
            // 防止重複點擊攔截
            if ($this.prop("disabled") || $this.hasClass("loading")) return;
            //查詢是否有設定停止報名設定，有則要先顯示停止報名訊息
            const url = '@Url.Action("StopEnterTempMsg", "Ajax")';
            // 1. 立即停用按鈕，防止在 AJAX 回應前再次點擊
            $this.prop("disabled", true).addClass("loading").text("處理中...");
            ajaxLoadMore(url, {}, function (resp) {
                // 如果沒有停止報名的訊息，則進入下一階段驗證
                if (!resp || !resp.data) {
                    CheckSendEnterOnline2($this, $mainForm);
                } else {
                    // 檢核有不符報名條件
                    blockAlert(resp.data, "提示訊息", function () {
                        $this.prop("disabled", false).removeClass("loading").text("報名");
                    });
                }
            });
        });

        // 取消與回上頁邏輯 (保持原樣但快取) //取消回上頁-回明細頁 GoDetail
        const isOnlneSignUp = '@sm.IsOnlineSignUp';
        $("a[data-role=GoDetail], button[data-role=GoDetail]").click(function () {
            const formId = (isOnlneSignUp === "Y") ? "GoOnline1Form" : "GoDetailForm";
            $(`#${formId}`).submit();
        });
    });

    // 送出報名檢核函數優化
    function CheckSendEnterOnline2($btn, $form) {
        // 1. 前端基本資料讀取
        const yy = $("#Form_BIRTH_YEAR").val();
        const mm = $("#Form_BIRTH_MON").val();
        const dd = $("#Form_BIRTH_DAY").val();

        if (!yy || !mm || !dd) {
            blockAlert("出生日期資料不完整，請檢查後再試", "錯誤訊息", function() {
                $btn.prop("disabled", false).removeClass("loading").text("報名");
            });
            return;
        }

        // 2. 準備傳送資料
        const ocidVal = $("#Form_OCID").val();
        const planType = $("#Form_PlanType").val();
        const vDB3D0C = $("#Form_DB3D0C").val();
        const birth = (parseInt(yy, 10) + 1911) + "/" + mm + "/" + dd;
        const data = { ocid: ocidVal, planType: planType, birth: birth, DB3D0C: vDB3D0C };

        // 3. 發送 API 驗證
        $.ajax({
            url: '@Url.Action("CheckSendEnterOnline2", "Ajax")',
            type: 'POST',
            data: data,
            success: function (resp) {
                if (resp && resp.status) {
                    $form.submit(); // 驗證成功，送出表單
                } else {
                    const errorTxt = resp.data || "驗證失敗或報名人數眾多系統無法即時處理，請稍後再試";
                    blockAlert(errorTxt, "錯誤訊息", function () {
                        $btn.prop("disabled", false).removeClass("loading").text("報名");
                    });
                }
            },
            error: function () {
                blockAlert("報名人數眾多系統無法即時處理或伺服器異常，請稍後再試", "系統錯誤", function () {
                    $btn.prop("disabled", false).removeClass("loading").text("報名");
                });
            }
        });
    }
</script>
