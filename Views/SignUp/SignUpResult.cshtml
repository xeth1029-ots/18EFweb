@{
    ViewBag.Title = "課程查詢報名--課程報名結果";
    Layout = "~/Views/Shared/_MainLayout_NoClassSearchNoGTM.cshtml";
}

<div class="col-sm-12">
    <!-- bread start --->
    <div class="breadlink"><a title="中間主要功能選項區" accesskey="C" id="C" href="#C" style="text-decoration:none;">:::</a><i class="fa fa-home space-right" aria-hidden="true"></i>目前位置：<a href="@Url.Content("~/")" title="回首頁">首頁</a> / 課程報名結果</div>
    <!-- bread end --->
    <h3 class="main-title main-title-blue"><i class="fas fa-edit space-right"></i>課程報名結果</h3>
    <!-- news content start -->
    <div class="news-content">
        <div class="clearfix"></div>

        <!-- privacy start -->
        <div class="newsgroup">
            <div class="">
                <div class="unit-bg unit-bg-green">
                    <ol>
                        @Html.Raw(ViewBag.msg1)
                    </ol>

                </div>
            </div>
            <div class="clearfix"></div>
            <div>
                <input type="checkbox" id="chkShowSingNo" /><label for="chkShowSingNo">我已清楚了解，請顯示序號</label>
            </div>
            <div id="divSignNo" class="hidden">
                @ViewBag.signNoMsg
            </div>
            <div id="divSignNo2" class="hidden">
                @Html.Raw(@ViewBag.signNoMsg2)
            </div>
        </div>
        <!-- privacy end -->

    </div>
    <!-- news content end -->
</div>

<script type="text/javascript">
    $(function () {
        $("#chkShowSingNo").on("click", function () {
            //var divSignNo = $("#divSignNo");
            if (this.checked) {
                $("#divSignNo").removeClass("hidden");
                $("#divSignNo2").removeClass("hidden");
            } else {
                $("#divSignNo").addClass("hidden");
                $("#divSignNo2").addClass("hidden");
            }
        });
    });
</script>