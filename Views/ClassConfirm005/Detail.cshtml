@model WDAIIP.WEB.Models.ClassConfirm005ViewModel
@{
    ViewBag.Title = "課程錄訓名單--區域產業據點";
    Layout = "~/Views/Shared/_MainLayout_NoClassSearch.cshtml";
    string s_ODNUMBER = string.Format("{0}字 第{1}號", Model.Detail.ODNUMBER ?? "", Model.Detail.ODNUMBER2 ?? "");
}

@using (Html.BeginForm("Detail", "Classconfirm005", FormMethod.Post, htmlAttributes: new { id = "main_form", @class = "form-horizontal" }))
{
    Int32? i_OCID = (int)Model.Detail.OCID;

    <div class="col-sm-12">
        <!-- bread start --->
        <div class="breadlink">
            <a title="中間主要功能選項區" accesskey="C" id="C" href="#C" style="text-decoration:none;">:::</a>
            <i class="fa fa-home space-right" aria-hidden="true"></i>目前位置：<a href="@Url.Content("~/")" title="回首頁">首頁</a> / 課程錄訓名單 / 區域產業據點
        </div>
        <!-- bread end --->
        <h3 class="main-title main-title-green"><i class="fab fa-readme space-right"></i>課程錄訓名單</h3>

        <!-- note table-->
        <div class="table-responsive">
            <table width="100%" border="0" cellspacing="0" cellpadding="0" class="table  table-result">
                <tr>
                    <th width="15%">發布單位</th>
                    <td width="35%">@Model.Detail.CFORGNAME</td>
                    <th width="15%">課程代碼</th>
                    <td width="35%">@i_OCID</td>
                </tr>
                <tr>
                    <th>訓練單位</th>
                    <td>@Model.Detail.TRAINORG</td>
                    <th>公告日期</th>
                    <td>@Model.Detail.ANNMENTDATE_TW<a href="javascript:showclassdetail(5,'N',@Model.Detail.OCID)" title="前往檢視課程明細">課程連結</a></td>
                </tr>
                <tr>
                    <th>訓練班別</th>
                    <td><a href="javascript:showclassdetail(5,'N',@Model.Detail.OCID)" title="@Model.Detail.TRAINCLASS">@Model.Detail.TRAINCLASS<b></b></a></td>
                    <th>公告期間</th>
                    <td>@Model.Detail.ANNMENTDATERANGE</td>
                </tr>
                <tr>
                    <th>文號</th>
                    <td colspan="3">@s_ODNUMBER </td>
                </tr>
            </table>
        </div>

        <div class="table-responsive">
            <table width="100%" border="0" cellspacing="0" cellpadding="0" class="table search-table table-blue">
                <thead>
                    <tr>
                        <th width="25%">編號</th>
                        <th width="25%">姓名</th>
                        <th width="25%">身分證字號</th>
                        <th width="25%">備註</th>
                    </tr>
                </thead>
                <tbody>
                    @Html.Partial("_UserGridRows", Model)
                </tbody>
            </table>
        </div>

        <div class="submit-bar">
            <button type="button" class="btn-orange" onclick="goback()" title="回上一頁">回上一頁</button>
        </div>
        <p><p>
    </div>
}
<script type="text/javascript">
    //回上一頁
    function goback(OCID_TEXT, CLASSCNAME, DISTIDITEM) {
        var data = { "OCID_TEXT": OCID_TEXT, "CLASSCNAME": CLASSCNAME, "DISTIDITEM": DISTIDITEM };
        var url = '@Url.Action("Index", "ClassConfirm005")';
        goBackPage(url, data, 2, 'POST');
    }

    function showclassdetail(PlanType, ProvideLocation, OCID) {
        var data = { "PlanType": 5, "ProvideLocation": 'N', "OCID": OCID };
        var url = '@Url.Action("Detail", "ClassSearch")';
        goBackPage(url, data, 2, 'POST');
    }
</script>