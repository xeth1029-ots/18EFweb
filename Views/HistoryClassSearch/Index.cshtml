@model WDAIIP.WEB.Models.ClassSearchViewModel

@{ 
    ViewBag.Title = "課程查詢報名--歷史課程查詢";
    Layout = "~/Views/Shared/_MainLayout_NoClassSearch.cshtml";
    return;
}

<style type="text/css">
    .group-width input {
        margin-right: 8px;
    }

    .group-width label {
        margin-right: 13px;
    }
</style>

@using (Html.BeginForm("Index", "HistoryClassSearch", FormMethod.Post, new { id = "main_form", @class = "form-horizontal" }))
{
    <div class="col-sm-12">
        <!-- bread start --->
        <div class="breadlink"><a title="中間主要功能選項區" accesskey="C" id="C" href="#C" style="text-decoration:none;">:::</a><i class="fa fa-home space-right" aria-hidden="true"></i>目前位置：<a href="@Url.Content("~/")" title="回首頁">首頁</a> / 課程查詢報名 / 歷史課程查詢</div>
        <!-- bread end --->
        <h3 class="main-title main-title-blue"><i class="fas fa-search space-right"></i>歷史課程查詢條件</h3>

        <!-- search form start -->
        <div class="unit-border">
            <div class="form-group-search">
                @*@Html.CustomLabelFor(m => m.Form.PlanType, new { @class = "form-label-search" })*@
                <label for="Form_PlanType_2" class="form-label-search">類別</label>
                <div class="form-input form-inline">
                    @Html.RadioGroupFor(m => m.Form.PlanType, Model.HisPlanType_list, new { @class = "group-width", title = "請選擇計畫別" })
                </div>
            </div>
            <!-- 條件 start -->
            <div id="condition">
                @Html.Partial("_Condition")
            </div>
            <!-- 條件 end -->
            <div class="clearfix"></div>
            <div class="submit-bar">
                <button type="submit" class="btn-orange" title="送出">送出</button>
                <button type="button" data-role="Reset" class="btn-refill" title="取消">取消</button>
            </div>
            <p>
            <p>
        </div>
        <!-- search form end -->
    </div>
}

@using (Html.BeginForm("PlanTypeChange", "HistoryClassSearch", FormMethod.Post, htmlAttributes: new { id = "condition_form", @class = "form-horizontal" }))
{
    @Html.Hidden("PlanType");
}

<script type="text/javascript">
    $(function () {
        var idHead = "#Form_";

        //類型選取項目改變事件
        $("input[type=radio][name*='Form.PlanType']").on("change", function () {
            doChangeCondition($(this).val());
        });

        //縣市代碼連動事件
        $(idHead + "CTID").on("change", doZipCodeGet);

        //訓練業別下拉連動事件
        $(idHead + "JOBTMID").on("change", doTMIDGet);

        //取消click事件(重載頁面)
        $("button[data-role=Reset]").on("click", function () {
            doChangeCondition($("input[name*='Form.PlanType']:checked").val());
        });

        //無障礙檢測 EV1080300 按照內容的序列及關連性來安排互動元件的放置順序
        //切換計畫選項post後，其focus狀態仍要停在原位
        var isFirst = '@Model.Form.IsFirst';
        var planType = '@Model.Form.PlanType';
        if (isFirst == "N") {
            if (planType != "") {
                $("input[id='Form_PlanType_" + planType + "']").focus();
            }
        }
    });

    //切換查詢條件
    function doChangeCondition(plantype) {
        $("#PlanType").val(plantype);
        $("form#condition_form").submit();
    }

    //取得縣市代碼相對應的鄉鎮市區清單
    function doZipCodeGet() {
        var idHead = "#Form_";
        var data = {
            "url": "@Url.Action("GetZipCode", "Ajax")",
            "arg": { "CTID": $(idHead + "CTID option:selected").val() },
            "box": $(idHead + "ZIPCODE")
        }

        var blankHtml = "<option value=\"\">請選擇</option>";
        if ($.trim(data.arg.CTID) == "") data.box.html(blankHtml);
        else {
            ajaxLoadMore(data.url, data.arg, function (resp) {
                if (resp === undefined) data.box.html(blankHtml);
                else {
                    if (resp.data != "") {
                        data.box.html(resp.data);
                    }
                    else {
                        data.box.html(blankHtml);
                    }
                }
            });
        }
    }

    //取得縮小單位範圍清單
    function doSchoolListGet() {
        var idHead = "#Form_";
        var data = {
            "url": "@Url.Action("GetSchoolList", "Ajax")",
            "arg": {
                "CTID": $(idHead + "CTID option:selected").val().trim(),
                "ZIPCODE": $(idHead + "ZIPCODE option:selected").val().trim(),
                "SCHOOLNAME": $(idHead + "SCHOOLNAME").val().trim()
            },
            "box": $(idHead + "COMIDNO")
        }

        var blankHtml = "<option value=\"\">全部</option>";
        if ($.trim(data.arg.CTID) == "" && $.trim(data.arg.ZIPCODE) == "" && $.trim(data.arg.SCHOOLNAME) == "") data.box.html(blankHtml);
        else {
            ajaxLoadMore(data.url, data.arg, function (resp) {
                if (resp === undefined) data.box.html(blankHtml);
                else {
                    if (resp.data != "") {
                        data.box.html(resp.data);
                    }
                    else {
                        data.box.html(blankHtml);
                    }
                }
            });
        }
    }

    //取得訓練業別「職類課程」對應的「業別」清單資料
    function doTMIDGet() {
        var idHead = "#Form_";
        var data = {
            "url": "@Url.Action("GetTMIDList","Ajax")",
            "arg": { "JOBTMID": $(idHead + "JOBTMID option:selected").val() },
            "box": $(idHead + "TMID")
    };

    var blankHtml = "<option value=\"\">請選擇</option>";
    if ($.trim(data.arg.JOBTMID) == "") data.box.html(blankHtml);
    else {
        ajaxLoadMore(data.url, data.arg, function (resp) {
            if (resp === undefined) data.box.html(blankHtml);
            else {
                if (resp.data != "") {
                    data.box.html(resp.data);
                } else {
                    data.box.html(blankHtml);
                }
            }
        });
    }
    }
</script>