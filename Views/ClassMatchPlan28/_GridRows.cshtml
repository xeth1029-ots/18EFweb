@model WDAIIP.WEB.Models.ClassMatchListViewModel
@using WDAIIP.WEB.DataLayers

@if (Model == null || Model.Grid1 == null || Model.Grid1.Count == 0)
{
    <tr valign="middle">
        <td colspan="12" style="text-align:center;">尚無資料</td>
    </tr>
}
else
{
    MyKeyMapDAO keyDao = new MyKeyMapDAO();
    DateTime nowTime = keyDao.GetSysDateNow();

    for (int i = 0; i < Model.Grid1.Count; i++)
    {
        var item = Model.Grid1[i];

        string strStatus = "招生中";
        string strColor = "black";
        if (item.SENTERDATE != null && item.FENTERDATE != null)
        {
            if (string.IsNullOrEmpty(Convert.ToString(item.TNUM))) { item.TNUM = 0; }
            int intCnt = (new MyKeyMapDAO()).GetEnterCount(item.OCID); // 取得報名人數 (扣除e網審核失敗)

            if (DateTime.Compare(nowTime, Convert.ToDateTime(item.SENTERDATE)) < 0)
            {
                strStatus = "尚未開始招生";
            }
            else if (DateTime.Compare(nowTime, Convert.ToDateTime(item.FENTERDATE)) > 0)
            {
                strStatus = "已招生結束";
            }
            else if (Convert.ToString(item.ISCLOSED) == "Y")
            {
                strStatus = "此班已結訓";
            }
            else if (Convert.ToString(item.ISCLOSED) == "N" && DateTime.Compare(nowTime, Convert.ToDateTime(item.FENTERDATE)) > 0 && (intCnt > item.TNUM))
            {
                strStatus = "接受以備取身份報名";

                if (!string.IsNullOrEmpty(Convert.ToString(item.ADMISSIONS)))
                {
                    switch (Convert.ToString(item.ADMISSIONS))
                    {
                        case "1": strStatus = "招生中"; strColor = "red"; break;
                        case "2": strStatus = "接受以備取身份報名"; break;
                        case "3": strStatus = "報名額滿"; strColor = "red"; break;
                    }
                }
            }
        }
        <tr valign="middle">
            <td><a title="@(item.CLASSCNAME)" href="javascript:doDetail('@(Model.Form.PlanType)','@Model.Form.ProvideLocation','@(item.OCID)');">@(item.CLASSCNAME)</a></td>
            <td align="center">@(item.OCID) @Html.HiddenFor(m => m.Grid1[i].OCID)</td>
            <td align="center">@(item.TNUM)</td>
            <td align="center">@(item.THOURS)</td>
            <td align="center">@(item.DEFSTDCOST)</td>
            <td align="center">@(item.DEFGOVCOST)</td>
            <td align="center">@(item.CTNAME1)</td>
            <td align="center">@(item.CTNAME2)</td>
            @*@if (Model.Form.ProvideLocation == "Y")//TODO:顯示距離
                        {
                    <td align="center">@(item.Distance)</td>
                }*@
            <td align="center">
                @if (item.SENTERDATE != null)
                {
                    @((Convert.ToDateTime(item.SENTERDATE).Year - 1911).ToString() + Convert.ToDateTime(item.SENTERDATE).ToString("/MM/dd HH:mm:ss"))
                }
                <br />|<br />
                @if (item.FENTERDATE != null)
                {
                    @((Convert.ToDateTime(item.FENTERDATE).Year - 1911).ToString() + Convert.ToDateTime(item.FENTERDATE).ToString("/MM/dd HH:mm:ss"))
                }
            </td>
            <td style="color:@strColor;">@strStatus</td>
            <td align="center">
                @(item.STDATE_TW)<br />|<br />@(item.FTDATE_TW)
            </td>
            <td>@item.ENTERSUPPLYSTYLE</td>
        </tr>
    }
}