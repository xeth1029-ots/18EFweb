@model WDAIIP.WEB.Models.DistClassSearchViewModel

@if (Model == null || Model.PLAN_list == null || Model.PLAN_list.Count == 0)
{
    <div>查無計畫資料</div>
}
else
{
    foreach (var item in Model.PLAN_list)
    {
        if ((Model.Form.PLANTYPE).Equals(item.Value))
        {
            <li class="plan-type"><a id="aPlanType_@(item.Value)" href="javascript:setPlanType('@item.Value')" class="active" title="@item.Text">@item.Text</a></li>
        }
        else
        {
            <li class="plan-type"><a id="aPlanType_@(item.Value)" href="javascript:setPlanType('@item.Value')" title="@item.Text">@item.Text</a></li>
        }
    }
}

