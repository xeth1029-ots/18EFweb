@model WDAIIP.WEB.Models.DownloadViewModel

@if (Model.DownloadType_list != null && Model.DownloadType_list.Count > 0)
{
    for (int i = 0; i < Model.DownloadType_list.Count; i++)
    {
        var item = Model.DownloadType_list[i];

        string t_PlanId = Model.Form.PLANID;
        if (string.IsNullOrEmpty(t_PlanId))
        {
            t_PlanId = "99";
        }

        if (t_PlanId.Equals(item.CODE))
        {
            <li><a href="javascript:doQuery('@item.CODE')" class="active" title="@item.TEXT">@item.TEXT</a></li>
        }
        else
        {
            <li><a href="javascript:doQuery('@item.CODE')" title="@item.TEXT">@item.TEXT</a></li>
        }
    }
}
else
{
    <div>查無資料</div>
}