    var url_addclasstrace="@Url.Action("AddClassTrace", "ClassMapSch")";
    var s_flag_login='@flag_login'; //var chkLogin='@flag_login';

    //課程收藏 AddClassTrace
    function doAddClassTrace(v_chk,v_OCID,s_cblab) {
        //console.log("chkLogin: "+chkLogin);
        //console.log("v_chk: "+v_chk+" , v_OCID: "+v_OCID)

        if(s_flag_login=='False'){
            $("#"+s_cblab).prop('checked', false);
            //alert('請先執行登入，再執行收藏最愛動作！');
            blockAlert('請先執行登入，再執行收藏最愛動作！');
            return;
        }

        let v_ADDCHK= (v_chk==true) ? "1":"0"; //ADDCHK: 0:取消收藏 1：增加收藏
        let data = {
            "url": url_addclasstrace,
            "arg": { "PlanType": $("#Form_PlanType").val() ,"OCID": v_OCID ,"ADDCHK": v_ADDCHK },
            "box": 'stopstop'
        };
        ajaxLoadMore(data.url, data.arg, function (resp) {
            if (resp) {
                if (resp.status) {
                    if (resp.data != "") {
                        blockAlert(resp.data,"提示訊息", function(){});
                    }
                    else{
                        blockAlert("執行收藏動作?","訊息", function(){});
                    }
                } else {
                    //收藏失敗
                    if (resp.data != "") {
                        blockAlert(resp.data, "注意訊息", function () {});
                    }
                }
            }

        });
    }

</script>
