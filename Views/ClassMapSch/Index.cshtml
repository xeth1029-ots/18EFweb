    /* 搜尋地圖區域 */
    function btnBoundSearchClick() {

        // 在地圖加上 loading mask
        //loadingMask("body");

        // 清除縣市條件
        //$("[id*=ddlCity]").val("");
        //$("[id*=CascadingDropDown1_ClientState]").val("");

        // 地圖顯示區域的 座標範圍
        let env = leafletApi.getMapBounds();
        // 組成能夠安全傳至後端的字串格式:  left/right/top/bottom
        let bounds = "" + env.left + "/" + env.right + "/" + env.top + "/" + env.bottom;

        $("input[id*=hidSearchBounds]").val(bounds);

        doSearch();
    }

    /* 定位使用者位置 */
