            function (p) {
                leafletApi.setCenter(p, userZoom);
                leafletApi.setSingleMarker(p, 40, "您所在的位置");
                //removeLoadingMask();
            },
            function (msg) {
                //removeLoadingMask();
                alert("定位失敗: \n" + msg);
            }
        );
    }

