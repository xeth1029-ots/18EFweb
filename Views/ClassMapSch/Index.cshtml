<script type="text/javascript">
    var jobBounds = null;//undefined;
    var searchLoc = null;//undefined;
    var searchBounds = null;//undefined;
    var isMarkerFocused = false;
    // 通知 onMapBoundsChanged() 不要連動更新右側站台清單
    var preventBoundsChangeRefreshList = false;
    //var idHead = "#Form_";
    var url_detail_ClassSearch = '@Url.Action("Detail", "ClassSearch")';

    //$(document).ready(function () {
    //    訓練業別下拉連動事件
    //    $("#Form_JOBTMID").on("change",function(){ doTMIDGet();});
    //});

    $(document).ready(function () {
        blockUI(); //unblockUI(); blockUI();

        mapListRwd.init('.list_zone');

        jobBounds = $.parseJSON($("input[id*=hidJobBounds]").val());
        if ($("input[id*=hidSearchLoc]").val() != "") {
            searchLoc = $.parseJSON($("input[id*=hidSearchLoc]").val());
        }

        var hidOpenNotSearch = $("input[id*=hidOpenNotSearch]").val();

        // hidSearchBounds 格式是前次傳至後端的字串格式:  left/right/top/bottom
        var bounds = $("input[id*=hidSearchBounds]").val().split('/');
        if (bounds.length == 4) {
            searchBounds = {
                'left': bounds[0],
                'right': bounds[1],
                'top': bounds[2],
                'bottom': bounds[3]
            };
        }

        // binding Map event
        mapEventHandler.zoomend = onMapBoundsChanged;
        mapEventHandler.dragend = onMapBoundsChanged;

        // 地圖起始參數
        leafletApi.mapSetting.zoom = 8;  // 最大化顯示台灣地圖範圍

        leafletApi.initMap("map", function () {
            console.log("Map ready");

            if ("Y" != hidOpenNotSearch) {

                showJobMarkers();

                var selCity = $("[id*=ddlCity] option:selected").val();
                if (selCity) {
                    // 查詢縣市, // 抓取 GeoJson 資料進行地理區域標示
                    showGeoArea(selCity);
                }

            }

            if (searchLoc && searchLoc != 'undefined' && searchLoc != null) {
                //var mPoint = new TGOS.TGPoint(searchLoc.x, searchLoc.y);
                //leafletApi.setSingleMarker([searchLoc.y, searchLoc.x], 40, $("input[id*=txt_AddrKeyword]").val());
            }
        });


        // 避免 Enter 觸發 form POST
        $('form input:not([type="submit"])').keydown(function (e) {
            if (e.keyCode == 13) {
                e.preventDefault();
                return false;
            }
        });

        unblockUI(); //unblockUI(); blockUI();
    });

    function onMapBoundsChanged(e) {
        /* console.log("onMapBoundsChanged");console.log(e);      var geo = leafletApi.getMapBounds();console.log(geo);
        if (!isMarkerFocused && !preventBoundsChangeRefreshList) {
            // 更新右側職缺列表
            setTimeout(function () {
                refreshJobList(geo);
            }, 100); }
        // always reset 
        // preventBoundsChangeRefreshList = false; 
        */
    }

    //var g_ctname ="";
    function showJobMarkers() {
        // 標點顏色
        let colors = ["#d64161", "#ff7b25", "#30ae30"];
        // 準備標記點資料
        let markerDatas = [];

        // 找出所有職缺資訊
        $(".list_zone").find("ul").each(function () {
            let job = {};
            let metaLi = $(this).find("li.meta");
            job.HireId = metaLi.find("span#HireId").text();
            job.JobName = metaLi.find("span#JobName").text();
            job.CtName = metaLi.find("span#CtName").text();
            job.MAP_X = metaLi.find("span#TWD97_X").text();
            job.MAP_Y = metaLi.find("span#TWD97_Y").text();

            //沒有座標點, 略過
            let locX = parseFloat(job.MAP_X);
            let locY = parseFloat(job.MAP_Y);
            if (isNaN(locX) || isNaN(locY)) {
                $(this).hide();
                return;
            }

            // binding job list item event
            $(this)
                .on("click", function () { jobListItemClick($(this).data("id")); })
                .mouseenter(function () { jobListItemHoverIn($(this).data("id")); })
                .mouseleave(function () { jobListItemHoverOut($(this).data("id")); })

            var markerData = {};
            markerData.id = job.HireId;
            markerData.name = job.JobName;
            markerData.ctname = job.CtName;
            //markerData.markerImgUrl = getImgUrl(1);
            markerData.locX = locX;
            markerData.locY = locY;
            markerData.fillColor = colors[0];
            markerData.textColor = "#FFF";
            //markerData.onClick = jobMarkClick;
            markerData.data = job;
            markerDatas.push(markerData);
        });

        $("#search_map_list_title").html("共 <span>" + markerDatas.length + "</span> 筆課程地圖");

        // 判斷是否為「地圖範圍」搜尋, 若是就不要根據點位自動縮放
        let fitBounds = (searchBounds != undefined && searchBounds != null) ? false:true;
        leafletApi.setMarkers(markerDatas, onMarkerClick, 0, '筆', fitBounds);

        if (searchBounds && searchBounds != undefined && searchBounds != null) {
            leafletApi.setMapBounds(searchBounds);
        }
    }

    // 地圖 cluster 點位 click 事件處理
    function onMarkerClick(m) {
        //console.log("onMarkerClick"); //console.log(m);

        isMarkerFocused = true;

        // 更新右側站台清單
        let locZone = $(".list_zone");
        locZone.find("ul").hide();

        // 重新過濾右側職缺清單, 只顯示點選 marker 包含的職缺
        let jobCount = 0;
        for (var k = 0; k < m.length; k++) {
            locZone.find("ul[data-id=" + m[k].itemId + "]").show("slow");
            jobCount++;
        }

        $("#search_map_list_title").html("該位置附近有 <span>" + jobCount + "</span> 筆課程地圖");

        // 行動裝置環境中, 重設列表清單至第1個位置
        mapListRwd.resetList();
    }

    // 點選右側列表Job
    function jobListItemClick(hireId, JobName, locX, locY) {
        setMarkerMapCenter(locX, locY, hireId, JobName);
        // 右側清單點選項目置頂
        //var d = {}; d.id = hireId;
        //jobMarkClick(d);
    }

    // 右側清單, 最後 highlight 對應的點位 cluster marker
    var curHighlightMarker;

    function jobListItemHoverIn(jobId) {
        //console.log("jobListtItemHoverIn: " + jobId);

        if (curHighlightMarker != undefined && curHighlightMarker != null && curHighlightMarker.removeIconClass) {
            curHighlightMarker.removeIconClass("custom-cluster-hint");
            curHighlightMarker = undefined;
        }

        let marker = leafletApi.findMarkerByItemId(jobId);
        if (marker != undefined && marker != null) {
            // 找到點位, 同時在顯示範圍
            curHighlightMarker = marker;
            marker.addIconClass("custom-cluster-hint");
        }
    }

    function jobListItemHoverOut(jobId) {
        //console.log("jobListtItemHoverOut: " + jobId);

        if (curHighlightMarker != undefined && curHighlightMarker.removeIconClass) {
            curHighlightMarker.removeIconClass("custom-cluster-hint");
            curHighlightMarker = undefined;
        }
        else {
            let marker = leafletApi.findMarkerByItemId(jobId);
            if (marker != undefined && marker != null) {
                // 找到點位, 同時在顯示範圍
                marker.removeIconClass("custom-cluster-hint");
            }
        }
    }

    // 點選右側列表
    function jobListItemClick(jobId) {
        let marker = leafletApi.findMarkerByItemId(jobId);
        if (marker != undefined && marker != null) {
            // 找到點位, 同時在顯示範圍

            // 通知 onMapBoundsChanged() 不要連動更新右側站台清單
            preventBoundsChangeRefreshList = true;

            // 加上提示的CSS樣式
            marker.addIconClass("custom-cluster-hint");

            // 將點位移到地圖中央
            leafletApi.setCenter(marker.getLatLng());
        }
    }

    //showclassdetail
    function showclassdetail(PlanType, ProvideLocation, OCID) {
        let data = { "PlanType": PlanType, "ProvideLocation": 'N', "OCID": OCID };
        let url = url_detail_ClassSearch;
