<script>
    // 上方搜尋框下拉選單 點擊變換顏色
    $('#map_search select').on('change', function() {
        var $this = $(this);
        $this.css('color', $this.val() == '' ? '#838588' : '#212529');
    });

    $('.select').bind('keydown', function(event) {
        var code = event.keyCode || event.which;
        var _this = $(this);
        if (code == 13) {
            _this.click();
        }
    });
    // 左側選單整塊開關
    (function lt_mb_open() {

        var header = $('h4.accordions');
        var lab = $('.chk-inp');
        header.attr('tabindex', '0');
        lab.attr('tabindex', '0');

        $('.icon-bk').on('click', function() {
            var $this = $(this);
            $this.find('#lt_more').toggleClass('nre-remove-square nre-add-square').parent().parent().next('div.lt-more-accordions').toggleClass('open');
        });

        // 查詢條件收合動態
        header.on('click', function() {
            var $this = $(this);
            $this.toggleClass('show');
            $this.next('ul.accordions-cnt').slideToggle(200);
        });

        $('.lt-more-accordions').find('.chk-inp , h4.accordions').bind('keydown', function(event) {
            var code = event.keyCode || event.which;
            var _this = $(this);
            if (code == 13 || code == 32) {
                _this.click();
            }
        });
        // 左側選單展開事件
        function accordionsOpen(Index) {
            var side_item = $(".lt-more-cnt h4.accordions").eq(Index);
            var sub_list = side_item.next(".accordions-cnt");
            //side_item.addClass("show");
            side_item.show().addClass("show");
            sub_list.slideDown(200);
        }
        function accordionsClose(Index) {
            let side_item = $(".lt-more-cnt h4.accordions").eq(Index);
            let sub_list = side_item.next(".accordions-cnt");
            side_item.hide().removeClass("show");
            sub_list.slideUp(200);
        }
        // 執行時參數代入 index 值，展開左側選單
        accordionsOpen(0);
    }());

    // 左側進階搜尋 監聽
    $('.accordions-cnt input').each(function() {
        var $this = $(this);
