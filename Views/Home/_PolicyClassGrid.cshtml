@model WDAIIP.WEB.Models.HomeViewModel

@if (Model.PolicyClassGrid != null && Model.PolicyClassGrid.Count > 0)
{

    foreach (var item in Model.PolicyClassGrid)
    {
        string plantype = "";
        switch (item.TPLANID)
        {
            case "28":
                plantype = "1";
                break;
            case "06":
                plantype = "2";
                break;
            case "70":
                plantype = "5";
                break;
        }
        <li><a href="javascript:showClassDetail(@plantype,@item.OCID);" title="@item.CLASSCNAME">@item.CLASSCNAME</a></li>
    }

}
else
{
    <li><center>尚無資料</center></li>
}
