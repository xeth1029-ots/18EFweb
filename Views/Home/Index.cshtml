@model WDAIIP.WEB.Models.HomeViewModel
@using WDAIIP.WEB.Models

@{
    Layout = "~/Views/Shared/_MainLayout.cshtml";
    NoticeDetailModel notice = Model.Notice;
    string s_tplanid28_url1 = ConfigModel.tplanid28_url1;
    string s_tplanid54_url1 = ConfigModel.tplanid54_url1;
    string s_tplanid06_url1 = ConfigModel.tplanid06_url1;
    string s_core_url1 = ConfigModel.core_url1;
    string s_coursefly_url1 = ConfigModel.coursefly_url1;

}

<!--index-main banner -->
<div class="col-sm-12">
    @*<div class="row"><div class="main-ad"><a href="#">
        <img src="@Url.Content(ConfigModel.UploadTempPath + "/BANNER/")@Model.BigBanner.FILE_NAME" alt="banner" id="banner" class="img-responsive"></a></div></div>*@
    <div class="row main-ad">
        <div id="myCarousel" class="carousel slide" data-ride="carousel">
            <!-- Indicators -->
            <ol class="carousel-indicators">
                @if (Model.BigBannerGrid != null)
                {
                    for (int i = 0; i < Model.BigBannerGrid.Count; i++)
                    {
                        <li data-target="#myCarousel" data-slide-to="@i" class="@(i == 0 ? "active" : "")"></li>
                    }
                }
            </ol>
            <!-- Wrapper for slides -->
            <div class="carousel-inner">
                @*<div class="item active"> <img src="@Url.Content(ConfigModel.UploadTempPath + "/BANNER/")@Model.BigBanner.FILE_NAME" alt="banner" style="width:100%;"> </div>
                    <div class="item"> <img src="@Url.Content(ConfigModel.UploadTempPath + "/BANNER/")@Model.BigBanner.FILE_NAME" alt="banner" style="width:100%;"> </div>*@
                @Html.Partial("_BigBannerGrid", Model)

            </div>
            <!-- Left and right controls -->
            <a class="left carousel-control" href="#myCarousel" data-slide="prev" title="上一則[連結]">
                <i class="fas fa-chevron-left"></i>
                <span class="sr-only">Previous</span>
            </a>
            <a class="right carousel-control" href="#myCarousel" data-slide="next" title="下一則[連結]">
                <i class="fas fa-chevron-right"></i>
                <span class="sr-only">Next</span>
            </a>
        </div>
    </div>
</div>

<div class="clearfix"></div>
<div class="row">
    <!-- news list -->
    <div class="col-sm-6">
        <h3 class="main-title titlebar-pinky">
            @*fix 無障礙檢測:EV1050101：確認所有功能都能透過鍵盤介面來操作*@
            <a title="中間主要功能選項區" accesskey="C" id="C" href="#C" style="text-decoration:none;">:::</a>

            <i class="far fa-newspaper space-right"></i>焦點消息<a href="@Url.Content("~/News")" class="main-more" title="前往看更多焦點消息">看更多</a>
        </h3>
        <div class="table-responsive">
            <table width="100%" border="0" cellspacing="0" cellpadding="0" class="table-index table-pink table">
                @Html.Partial("_NewsGrid", Model)
            </table>
        </div>
    </div>
    <!-- 計畫公告 list -->
    <div class="col-sm-6">
        <h3 class="main-title titlebar-green"><i class="fa fa-book space-right"></i>計畫公告<a href="@Url.Content("~/Plan")" class="main-more" title="前往看更多計畫公告">看更多</a></h3>
        <div class="table-responsive">
            <table width="100%" border="0" cellspacing="0" cellpadding="0" class="table-index table-green table">
                @Html.Partial("_PlanGrid", Model)
            </table>
        </div>
    </div>
</div>

@*首頁 各項訊息 區*@
@section msgArea {
    <div class="clearfix"></div>
    <div class="bg-share">
        <div class="container">
            <div class="row">
                @*最多分享課程 功能區*@
                <div class="col-sm-6">
                    <div class="bg-board">
                        @if (Model.PolicyClassGrid != null && Model.PolicyClassGrid.Count > 0)
                        {
                            <h3 class="main-title titlebar-blue">
                                <i class="fa fa-share-alt space-right"></i>政策性課程專區
                                <a href="@Url.Content("~/ClassSearch/ClassSch2")" class="main-more" title="前往查詢更多課程">看更多</a>
                                <a href="@Url.Content("~/HistoryPolicySch/ClassSch2")" class="main-more" title="前往查詢更多課程-歷史">歷史課程</a>
                            </h3>
                            <ul class="shareLink">@Html.Partial("_PolicyClassGrid", Model)</ul>
                        }
                        else
                        {
                            <h3 class="main-title titlebar-blue">
                                <i class="fa fa-share-alt space-right"></i>歷史政策性課程
                                <a href="@Url.Content("~/HistoryPolicySch/ClassSch2")" class="main-more" title="前往查詢更多課程-歷史">看更多</a>
                            </h3>
                            <ul class="shareLink">@Html.Partial("_PolicyClassHisGrid", Model)</ul>
                        }
                        @*最多分享課程 <a href="@Url.Content("~/ClassSearch")" class="main-more" title="前往查詢更多課程">看更多</a>*@
                    </div>
                </div>
                @*宣導影片 功能區*@
                <div class="col-sm-6">
                    <div class="bg-video">
                        <h3 class="main-title titlebar-red">宣導影片</h3>
                        @Html.Partial("_Film", Model)
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- plan area -->
    <div class="container">
        <div class="row">
            @*計畫簡介區*@
            <div class="col-sm-12">
                @*HM1110112E 對於輔助科技應當要忽略的圖片，使用空字串作為替代文字，並且不可使用標題屬性*@
                <h3 class="planZone-title"><a href="#"><span class="sr-only">連結計畫簡介</span><img src="@Url.Content("~/images/icon-plan.png")" class="img-responsive" alt="">計畫簡介</a></h3>
                <div class="planZone">
                    @*<div class="planZone-title"><a href="#"><img src="@Url.Content("~/images/icon-plan.png")" class="img-responsive" alt="計劃簡介">計劃簡介</a></div>*@
                    <ul class="planZone-list">
                        <li><a href="@s_tplanid28_url1" target="_blank" rel="noreferrer noopener" title="前往產業人才投資方案(另開新視窗)"><i class="fas fa-chalkboard-teacher"></i>(另開新視窗)<br />產業人才投資方案</a></li>
                        <li><a href="@s_tplanid54_url1" target="_blank" rel="noreferrer noopener" title="前往充電起飛計畫(另開新視窗)"><i class="fas fa-paper-plane"></i>(另開新視窗)<br />充電起飛計畫</a></li>
                        <li><a href="@s_tplanid06_url1" target="_blank" rel="noreferrer noopener" title="前往分署自辦在職訓練(另開新視窗)"><i class="fas fa-building"></i>(另開新視窗)<br />分署自辦在職訓練</a></li>
                        @*<li><a href="https://www.wda.gov.tw/News_Content.aspx?n=C3D5B0EEB25C0694&sms=6CA2172C29FEDCE9&s=86CB953436A321E1" target="_blank" title="前往分署接受企業委託辦理訓練(另開新視窗)"><i class="fas fa-briefcase"></i>分署接受企業委託辦理訓練</a></li>*@
                        @*<li><a href="http://163.29.199.223:8080/" target="_blank" title="前往共通核心職能課程(另開新視窗)"><i class="fas fa-book"></i>共通核心職能課程</a></li>*@
                        @*<li><a href="https://corecompetencies.wda.gov.tw/" target="_blank" title="前往共通核心職能課程(另開新視窗)"><i class="fas fa-book"></i>(另開新視窗)<br />共通核心職能課程</a></li>*@
                        <li><a href="@s_core_url1" target="_blank" rel="noreferrer noopener" title="前往關鍵就業力課程(另開新視窗)"><i class="fas fa-book"></i>(另開新視窗)<br />關鍵就業力課程</a></li>
                        <li><a href="@s_coursefly_url1" target="_blank" rel="noreferrer noopener" title="前往充電再出發訓練計畫(另開新視窗)"><i class="fas fa-paper-plane"></i>(另開新視窗)<br />充電再出發訓練計畫</a></li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
    <!-- banner zone -->

    <div class="bg-banner">
        <div class="container">
            <div class="row">
                <div class="col-sm-12">
                    <div id="main" role="main">
                        <section class="slider">
                            <div class="flexslider carousel">
                                <ul class="slides">
                                    @Html.Partial("_BannerGrid", Model)
                                </ul>
                            </div>
                        </section>
                    </div>
                </div>
            </div>
        </div>
    </div>

}

<!--<div class="gotop"><a href="#gotop"><i class="fa fa-level-up space-right" aria-hidden="true"></i>TOP</a></div>-->
@*系統公告提示訊息*@
<script type="text/html" id="notice-content" data-count="@(notice != null? 1 : 0)">
    <div>
        @if (notice != null)
        {
            @notice.C_CONTENT1
        }
    </div>
</script>

<script type="text/javascript">
    $('#myCarousel').on('slide.bs.carousel', function () {
        $('#myCarousel .carousel-control , .carousel-inner > a').focus(function () {
            $("#myCarousel").carousel('pause');
        }).blur(function () {
            $("#myCarousel").carousel('cycle');
        });
    });

    $(function () {
        // 顯示系統公告訊息
        var countStr = $('script#notice-content').attr('data-count');
        if (parseInt(countStr) > 0) {
            blockAlert($('script#notice-content').html(), "系統公告");
        }
    });

    // 檢視最新消息明細
    function showNews(seqno) {
        var data = { "seqno": seqno };
        var url = '@Url.Action("Detail", "News")';
        goForwardPage(url, data, 2, "POST");
    }

    // 檢視計畫公告明細
    function showPlan(seqno) {
        var data = { "seqno": seqno };
        var url = '@Url.Action("Detail", "Plan")';
        goForwardPage(url, data, 2, "POST");
    }

    // 檢視分享課程
    function showClassDetail(plantype, ocid) {
        var data = {
            "PlanType": plantype,
            "OCID": ocid,
            "ProvideLocation": "N"
        };
        var url = '@Url.Action("Detail", "ClassSearch")';
        goForwardPage(url, data, 2, "POST");
    }
</script>
