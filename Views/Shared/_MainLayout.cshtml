    <script type="text/javascript">
        @*2019-01-16 無障礙檢測：add 按esc鍵關閉彈跳視窗*@
        var app = {
            alertWindow: null,
            alertWindowCallback: [], // function[]
            confirmWindow: null,
            confirmWindowCallback: [], // function[]
        };
        //全域的Localhost路徑
        var _LocalhostURL = "@Request.Url.Scheme" + "://" + "@Request.Url.Authority" + ("@Request.ApplicationPath.Replace("/", "")" == "" ? "" : "/") + "@Request.ApplicationPath.Replace("/", "")";
        @* 前一個頁面最後錯誤或結果訊息 *@
        var lastErrorMessage = '@Html.Raw(sm.LastErrorMessage)';
        var lastResultMessage = '@Html.Raw(sm.LastResultMessage)';
        var redirectUrl = '@Html.Raw(sm.RedirectUrlAfterBlock)';
        @* 20190104 加入 RedirectByHttpMethod 引用 *@
        var redirectByHttpMethod = "@(sm.RedirectByHttpMethod)";

        function RedirectAfterPopup() {
            if (redirectUrl) {
                @*有指定 RedirectUrlAfterBlock, 進行重導動作 *@
                var form = $("form[name=RedirAfterBlockResult]");
                var p = redirectUrl.indexOf("?");
                if (p > 0) {
                    var parms = redirectUrl.substring(p + 1).split("&");
                    redirectUrl = redirectUrl.substring(0, p);
                    for (var i = 0; i < parms.length; i++) {
                        var ptoken = parms[i].split("=");
                        if (ptoken.length == 2) {
                            var input = document.createElement("input");
                            $(input).attr("type", "hidden");
                            $(input).attr("name", ptoken[0]);
                            $(input).attr("value", ptoken[1]);

                            form.append(input);
                        }
                        else {
                            debugTrace("RedirectUrlAfterBlock: parameter syntax error '" + parms[i] + "'");
                        }
                    }
                }
                //20190104 增加設定 form.method 設定
                form.attr("method", (redirectByHttpMethod === "GET") ? "get" : "post");
                form.attr("action", redirectUrl);
                form.submit();
            }
        }

