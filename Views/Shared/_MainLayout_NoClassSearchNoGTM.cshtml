    <script type="text/javascript">
        @*2019-01-16 無障礙檢測：add 按esc鍵關閉彈跳視窗*@
        var app = {
            alertWindow: null,
            alertWindowCallback: [], // function[]
            confirmWindow: null,
            confirmWindowCallback: [], // function[]
        };
        //全域的Localhost路徑
        var _LocalhostURL = "@Request.Url.Scheme" + "://" + "@Request.Url.Authority" + ("@Request.ApplicationPath.Replace("/", "")" == "" ? "" : "/") + "@Request.ApplicationPath.Replace("/", "")";
        @* 前一個頁面最後錯誤或結果訊息 *@
        var lastErrorMessage = '@Html.Raw(sm.LastErrorMessage)';
        var lastResultMessage = '@Html.Raw(sm.LastResultMessage)';
        var redirectUrl = '@Html.Raw(sm.RedirectUrlAfterBlock)';
        @* 20190104 加入 RedirectByHttpMethod 引用 *@
        var redirectByHttpMethod = "@(sm.RedirectByHttpMethod)";

        function RedirectAfterPopup() {
            if (redirectUrl) {
                @*有指定 RedirectUrlAfterBlock, 進行重導動作 *@
                var form = $("form[name=RedirAfterBlockResult]");
                var p = redirectUrl.indexOf("?");
                if (p > 0) {
                    var parms = redirectUrl.substring(p + 1).split("&");
                    redirectUrl = redirectUrl.substring(0, p);
                    for (var i = 0; i < parms.length; i++) {
                        var ptoken = parms[i].split("=");
                        if (ptoken.length == 2) {
                            var input = document.createElement("input");
                            $(input).attr("type", "hidden");
                            $(input).attr("name", ptoken[0]);
                            $(input).attr("value", ptoken[1]);

                            form.append(input);
                        }
                        else {
                            debugTrace("RedirectUrlAfterBlock: parameter syntax error '" + parms[i] + "'");
                        }
                    }
                }
                //20190104 增加設定 form.method 設定
                form.attr("method", (redirectByHttpMethod === "GET") ? "get" : "post");

                form.attr("action", redirectUrl);
                form.submit();
            }
        }

        var url_GetFooter = '@Url.Content("~/Ajax/GetFooter")';

        $(document).ready(function () {

            @* blockUI 引用的 loading image *@
            globalSetting.processingImg = "@Url.Content("~/images/processing.gif")";

            @* 前一個頁面最後錯誤或結果訊息 popup 處理*@
            if (lastErrorMessage) {
                blockAlert(lastErrorMessage, "錯誤訊息", function () {
                    RedirectAfterPopup()
                });
            }
            else if (lastResultMessage) {
                blockMessage(lastResultMessage, null, function () {
                    RedirectAfterPopup()
                });
            }
            else {
                @* 前一個表單 Post 後的 Validation Summary 訊息顯示 *@
                var IsValid = '@(ViewData.ModelState.IsValid)';
                var validationMsg = $("#ValidationSummary").html();
                if (IsValid == 'False' && validationMsg) {
                    blockAlert(validationMsg, "表單檢核訊息");
                }
            }

            @* 設定  div[class='wrap'] 的 min-height *@
            $("div.wrap").css("min-height",
                $("div.container-fluid").innerHeight()
                - $("div.header").outerHeight()
                - $("div.type-bar").outerHeight()
                );

            @*binding OnlineHelp button's click*@
            $("input[type=button][data-role=OnlineHelp]").click(function () {
                popupHelp();
            });

            @*動態載入頁尾資訊*@
            if (url_GetFooter != '') {
                ajaxLoadMore(url_GetFooter, {}, function (resp) {
                    //var div = $("div#footer-content");
                    $("div#footer-content").html(resp);
                });
            }

            @*$('form').each(function (index, item) {
                var el = $('<input type="hidden"/>');
                $(el).attr('name', '__SECURITY_FORM_ID__');
                $(el).attr('value', '@(DateTime.Now.ToString("yyyyMMdd"))');
                $(item).append(el);
            });*@

            $('body').on('submit', 'form', function (e) {
                var form = $(e.target);
                var el = $('<input type="hidden"/>');
                var chkObj = form.find("input[name='__SECURITY_FORM_ID__']").length; //2019-01-16 補加判斷不要重覆加hidden

                if (chkObj == 0) {
                    $(el).attr('name', '__SECURITY_FORM_ID__');
                    $(el).attr('value', '@(securityCode)');
                    $(form).append(el);
                }
            });

        });
    </script>
    <script type="text/javascript">
        $(function () {
            //SyntaxHighlighter.all();
            var activeFunID = "@(sm.ACTIVEFUNCTION)";

            $("li.dropdown").removeClass("active");

            if (activeFunID != "") {
                $("li.dropdown[data-role='mainmenu_" + activeFunID + "']").addClass("active");
            }

            //預設隱藏展開功能項link
            $("a[data-role=expand]").hide();

            //展開功能項事件
            $("a[data-role=expand]").on("click", function () {
                doExpand();
            });

            //收合功能項事件
            $("a[data-role=collapse]").on("click", function () {
                doExpand();
            });
        });
        $(window).load(function () {
            $('.flexslider').flexslider({
                animation: "slide",
                animationLoop: false,
                itemWidth: 185,
                itemMargin: 5,
                pausePlay: true,
                start: function (slider) {
                    $('body').removeClass('loading');
                }
            });
        });
    </script>
    <script type="text/javascript">
        @*2019-01-16 無障礙檢測：add 按esc鍵關閉彈跳視窗*@
        $(document).on('keyup', function (e) {
            if (app && app.confirmWindow) {  // app.confirmWindow in global.js: blockMessage function
                if (e.keyCode === 27) { // 如果按下esc
                    console.log('confirm escape press');
                    app.confirmWindow.close();
                }
            }
            if (app && app.alertWindow) {  // app.alertWindow in global.js: blockMessage function
                if (e.keyCode === 27) { // 如果按下esc
                    console.log('alert escape press');
                    app.alertWindow.close();
                }
            }
        });
    </script>
    <script>
        /* 就業通SSO登入階段追蹤碼 */
        var TwjobsSsoUuid = undefined;

        /* 就業通SSO登入階段追蹤 JS 套件會於載入後自動呼叫此 function */
        function TwjobsSsoUcodeReady(uuid) {
            TwjobsSsoUuid = uuid;
        }

        $(document).ready(function () {
            $(".btnLogout").click(function () {
                if (typeof xdSsoTrack !== 'undefined') {
                    //SSO 登出,debugger;會員登出,登出前,要先登出 TwjobsSsoTrack Session
                    xdSsoTrack.logoutSession(TwjobsSsoUuid, function (result) {
                        if (result.status == "OK") {
                            // 執行 登出
                            location.href = '@Url.Content("~/Member/Logout")';
                        }
                        else {
                            var tErrorMessage = "登出失敗，請直接關閉瀏覽器。";
                            alert(tErrorMessage); //blockAlert("登出失敗，請直接關閉瀏覽器。");
                        }
                    });
                }
                else {
                    // 2. 如果 xdSsoTrack 沒載入 (例如被擋掉或載入失敗)，直接執行本地登出,避免使用者按了按鈕卻完全沒反應
                    console.log("xdSsoTrack 未定義，直接執行本地登出");
                    location.href = '@Url.Content("~/Member/Logout")';
                }
            });
        });
        $(document).ready(function () {
            setTimeout(() => {
                if ($('.buttons .btn-info-Confirm').length > 0) { $('.buttons .btn-info-Confirm').focus(); }
            }, 3000); // 3000 milliseconds = 3 seconds
        });
    </script>
