        function ShowNowYear() {
            var now = new Date();
            var year = now.getFullYear();
            $("span#copyrightText").html(year);
        }

        // 展開/收合頁尾功能表
        function doExpand() {
            $("a[data-role=expand]").toggle();
            $("a[data-role=collapse]").toggle();
            $("#divFooter").slideToggle();
