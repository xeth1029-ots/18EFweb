@{
    ViewBag.Title = "線上報名即時統計";
    Layout = "~/Views/Shared/_MainLayout_NoClassSearch.cshtml";
}
<script type="text/javascript" src="https://www.gstatic.com/charts/loader.js"></script>
<script type="text/javascript">

    // Load the Visualization API and the corechart package.
    google.charts.load('current', { 'packages': ['corechart'] });

    // Set a callback to run when the Google Visualization API is loaded.
    google.charts.setOnLoadCallback(drawStatistics);

    var statistics = {
        current: 0,
        data: []
    }

    function drawStatistics() {
        // 資料來源 Url
        var dataUrl = '@Url.Action("Statistics" )';
        var parm = {};
        ajaxLoadJson(dataUrl, parm, function (result) {
            if (!result.data) {
                debugTrace(result);
                blockAlert("Statistics 回應內容不正確:");
                return;
            }
            statistics = result;

            processTimesChart();
            poolCapacityChart();
            waitTimesChart();
            waitCountChart();
            successCountChart();
            failCountChart();
            errorCountChart();
            timeoutCountChart();

            setTimeout(drawStatistics, 1000);

        }, false, true);

    };

    function resetStat() {
        var url = '@Url.Action("Reset")';

        ajaxLoadMore(url, {}, function (msg) {
            blockMessage(msg, "重設統計資訊");
        });
    }

    function getNextX(x) {
        x++;
        if (x >= statistics.data.length) { x = 0; }
        return x;
    }

    /*報名處理時間*/
    function processTimesChart() {
        var data = new google.visualization.DataTable();
        data.addColumn('string', '');  // X
        data.addColumn('number', '時間(毫秒)');     // Y

        var i = 0;
        var x = statistics.current + 1;
        var dataRows = [];
        while (i < statistics.data.length - 1) {
            x = getNextX(x);
            dataRows[i] = [String(x), statistics.data[x].AvgProcessTime];
            i++;
        }
        //console.log(dataRows);
        data.addRows(dataRows);
        var options = {
            title: '報名處理時間(毫秒)',
            width: 500,
            height: 150,
            titleTextStyle: { fontSize: 14 },
            legend: { position: 'none' },
            colors: ['#009'],
            vAxis: {
                minValue: 0,
                viewWindow: {
                    min: 0
                }
            }
        };

        var div = document.getElementById("processTimes")
        var chart = new google.visualization.LineChart(div);

        chart.draw(data, options);
    }

    /*等待時間*/
    function waitTimesChart() {
        var data = new google.visualization.DataTable();
        data.addColumn('string', '');  // X
