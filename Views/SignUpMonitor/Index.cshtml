    /*ThreadPool 使用量*/
    function poolCapacityChart() {

        var maxThreads = @(ViewBag.ProcessEnterWorkerMaxThreads);
        var currentProcess = statistics.data[statistics.current].Process;
        if(!currentProcess) { currentProcess = 0 }
        var availThreads = maxThreads - currentProcess;

        var dataRows = [];
        dataRows[0] = ["分類", "閒置Threads", "處理中", { role: 'annotation' } ];
        dataRows[1] = ["數值", availThreads, currentProcess, ''];

        var data = google.visualization.arrayToDataTable([
        ['分類', "處理中", "閒置Threads", { role: 'annotation' } ],
        ["", currentProcess, availThreads, '']
        ]);
        console.log(data);

        var options = {
            title: 'ThreadPool 使用/閒置 量(當下)',
            width: 500,
            height: 150,
            titleTextStyle: { fontSize: 14 },
            legend: { position: 'top' },
            colors: ['#900', '#090'],
            isStacked: true,
            hAxis: {
                format: '#'
            }
        };

        var div = document.getElementById("poolCapacity")
        var chart = new google.visualization.BarChart(div);

        chart.draw(data, options);
    }

</script>
<div class="col-md-12" style="text-align: center; margin-bottom:10px;">
    <label>主機：</label>@ViewBag.Host
    &nbsp;&nbsp;&nbsp;
    <label>報名ThreadPool容量設定：</label>@ViewBag.ProcessEnterWorkerMaxThreads
    &nbsp;&nbsp;&nbsp;
    <label>排隊等待逾時設定(秒)：</label>@ViewBag.ProcessEnterWorkerWaitTimeout
    &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
    <button type="button" onclick="resetStat()">重設統計資訊</button>
</div>
<div class="col-md-12" style="text-align: center">
    <!-- 統計表格/圖型 顯示用 container-->
    <div style="width: 1024px">
        <div id="processTimes" style="margin: 5px; float: left"></div>
        <div id="poolCapacity" style="margin: 5px; float: right"></div>
    </div>
    <div style="width: 1024px">
        <div id="waitTimes" style="margin: 5px; float: right"></div>
        <div id="waitCount" style="margin: 5px; float: left"></div>
    </div>
    <div style="width: 1024px">
        <div id="successCount" style="margin: 5px; float: left"></div>
        <div id="failCount" style="margin: 5px; float: right"></div>
    </div>
    <div style="width: 1024px">
        <div id="errorCount" style="margin: 5px; float: left"></div>
        <div id="timeoutCount" style="margin: 5px; float: right"></div>
    </div>
</div>



