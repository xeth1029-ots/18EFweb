@using WDAIIP.WEB.Commons;

@{
    ViewBag.Title = "政府網站資訊開放宣告";
    Layout = "~/Views/Shared/_MainLayout_NoClassSearch.cshtml";

    string content = (string)ViewBag.GovAnnounce;
}

<!-- content -->
<div class="col-sm-12">
    <!-- bread start --->
    <div class="breadlink"><a title="中間主要功能選項區" accesskey="C" id="C" href="#C" style="text-decoration:none;">:::</a><i class="fa fa-home space-right" aria-hidden="true"></i>目前位置：<a href="@Url.Content("~/")" title="回首頁">首頁</a> / 政府網站資訊開放宣告</div>
    <!-- bread end --->
    <h3 class="main-title main-title-green"><i class="fas fa-bullhorn space-right"></i>政府網站資訊開放宣告</h3>
    <!-- news content start -->
    <div class="news-content">
        <div class="clearfix"></div>
        <!-- govacconce start -->
        <div class="newsgroup">
            <p>@Html.Raw(string.IsNullOrEmpty(content) ? "尚無資訊" : MyHelperUtil.ChangeBreakLine(content))</p>
        </div>
        <!-- govacconce end -->
        
    </div>
    <!-- news content end -->
</div>
