@using WDAIIP.WEB.Models
@model ClassConfirm001ViewModel

@if (Model.Detail != null && Model.Detail.UserGrid.Count > 0)
{
    for(int i = 0; i < Model.Detail.UserGrid.Count; i++)
    {
        ClassConfirm0012GridModel item = Model.Detail.UserGrid[i];

        <tr>
            <td><div align="center">@(i + 1)</div></td>
            <td>@Html.Raw(item.STUDNAME2.Replace("○", "<i class=\"far fa-circle\"></i>"))</td>
            <td>@item.IDNO2</td>
            <td>@item.STUDMODE_N</td>
        </tr>
    }
}
else
{
    <tr><td colspan="4"><center>查無資料</center></td></tr>
}
